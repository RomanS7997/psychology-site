          <p class="text-2xl text-center text-white font-bold mb-8">18:00 - 19:00</p>
          
          <div class="bg-white/70 backdrop-blur-sm rounded-2xl p-6">
            <h4 class="font-bold text-gray-900 mb-4">Формат занятий:</h4>
            <ul class="space-y-3">
              <li class="flex items-center gap-3">
                <span class="text-[#4894B2] text-xl">✓</span>
                <span><strong>Длительность:</strong> 60 минут</span>
              </li>
              <li class="flex items-center gap-3">
