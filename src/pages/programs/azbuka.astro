---
// src/pages/programs/azbuka.astro
import Layout from '../../layouts/Layout.astro';
import ScrollAnimations from '../../components/ScrollAnimations.astro';
import AutoGallerySlider from '../../components/AutoGallerySlider.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SEO from '../../components/SEO.astro';
import FAQ from '../../components/FAQ.astro';
// Генерируем массив изображений для галереи (48 фото)
const galleryImages = Array.from({length: 48}, (_, i) => ({
  src: `/images/gallery/azbuka/${i + 1}.jpg`,
  alt: `Занятие Азбука общения - фото ${i + 1}`,
  caption: i % 4 === 0 ? 'Изучаем эмоции и чувства' : 
           i % 4 === 1 ? 'Ролевые игры и взаимодействие' : 
           i % 4 === 2 ? 'Творческое самовыражение' :
           'Работа в группе и общение'
}));
---

<SEO 
  title="Азбука общения - Развитие EQ в Одинцово | Для детей 5-9 лет"
  description="Программа Азбука общения в Одинцово. Развитие эмоционального интеллекта для детей 5-9 лет. Умение общаться, дружить, понимать эмоции."
  keywords="эмоциональный интеллект детей, развитие EQ, занятия для детей Одинцово"
  schema="service"
/>

<Layout 
  title="Азбука общения - Развитие EQ в Одинцово | Для детей 5-9 лет"
  description="Психологический курс для детей 5-9 лет. Развитие эмоционального интеллекта, работа со страхами, навыки общения. Группы до 8 детей."
>

  

  <!-- Баннер срочности -->
  <div class="fixed top-24 left-0 right-0 bg-gradient-to-r from-[#4894B2] to-[#18698F] text-white py-3 z-40 shadow-lg">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="flex items-center justify-center gap-4 text-center flex-wrap">
        <span class="text-2xl">✨</span>
        <p class="font-bold text-lg">
          Набор открыт! Начало занятий: <strong>15 февраля</strong>
        </p>
        <button 
          onclick="openBookingModal()"
          class="px-6 py-2 bg-white text-[#4894B2] rounded-full font-semibold hover:bg-gray-100 transition"
        >
          Записаться
        </button>
      </div>
    </div>
  </div>


  <section class="relative pt-40 pb-20 overflow-hidden bg-gradient-to-br from-[#F2F7FD] via-white to-[#F2F7FD]" data-animate="fade">
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
      <div class="grid md:grid-cols-2 gap-12 items-center max-w-7xl mx-auto">
        
        <!-- Текст -->
        <div>
          <div class="inline-block px-4 py-2 bg-[#4894B2] text-white rounded-full font-semibold mb-4">
            Программа для детей 5-9 лет
          </div>
          
          <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-[#4894B2] to-[#18698F] bg-clip-text text-transparent">
            "Азбука общения"
          </h1>
          
          <p class="text-2xl text-gray-700 mb-6 font-semibold">
            Курс развития эмоционального интеллекта
          </p>

          <p class="text-lg text-gray-700 mb-8 leading-relaxed">
            Психологический курс, который знакомит детей со сложным миром человеческих эмоций. 
            Дети учатся понимать, проявлять и реагировать на свои и чужие эмоции.
          </p>
          
          <div class="flex flex-wrap gap-4 mb-8">
            <button 
              onclick="openBookingModal()" 
              class="px-8 py-4 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full font-semibold transition shadow-lg hover:shadow-xl hover:scale-105"
            >
              Записаться на консультацию
            </button>
            <button 
              onclick="openBookingModal('specialist')" 
              class="px-8 py-4 bg-white hover:bg-[#F2F7FD] text-[#4894B2] border-2 border-[#4894B2] hover:border-[#18698F] rounded-full font-semibold transition"
            >
              Первичная консультация
            </button> 
          </div>
          
          <!-- Быстрые факты -->
          <div class="grid grid-cols-3 gap-6" data-stagger>
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4894B2] mb-2">5-9</div>
              <div class="text-sm text-gray-600">возраст</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4894B2] mb-2">4</div>
              <div class="text-sm text-gray-600">занятия/месяц</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4894B2] mb-2" data-counter="88" data-suffix="%">0</div>
              <div class="text-sm text-gray-600">улучшение поведения</div>
            </div>
          </div>
        </div>
        
          <!-- Изображение -->
        <div class="flex justify-center lg:justify-end " >
        <div class="relative w-full max-w-md">
          <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-2xl">
            <img 
              src="/images/gallery/azbuka/47.jpg" 
              alt="Консультация психолога" 
              class="w-full h-auto"
            />
          
          <!-- Декоративные элементы -->
          <div class="absolute -top-6 -right-6 w-24 h-24 bg-[#F2F7FD] rounded-full opacity-30 blur-2xl"></div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-[#F2F7FD] rounded-full opacity-30 blur-2xl"></div>
        </div>
        
      </div>
    </div>
  </section>
<Breadcrumbs 
    items={[
      { label: 'Главная', href: '/' },
      { label: 'Программы', href: '/#programs' },
      { label: 'Азбука общения' }
    ]}
  />
  </div><!-- 
  Что ребенок развивает -->
  <section class="py-20 bg-white" data-animate="slide-up">
    <div class="container mx-auto px-4 lg:px-8">
      <h2 class="text-4xl md:text-5xl font-bold text-center mb-4">
        Что ребенок развивает на занятиях
      </h2>
      <p class="text-center text-gray-600 text-lg mb-16 max-w-2xl mx-auto">
        Формирование высокого эмоционального интеллекта — важнейший фактор успешного общения
      </p>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        
        <!-- Навык 1 -->
        <div class="bg-gradient-to-br from-[#F2F7FD] to-white rounded-2xl p-8 hover:shadow-xl transition-all duration-300">
          <div class="text-5xl mb-4 text-center">💪</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 text-center">Уверенность в себе</h3>
          <ul class="space-y-2 text-sm text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-[#4894B2] mt-1">•</span>
              <span>Повышение самооценки</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#4894B2] mt-1">•</span>
