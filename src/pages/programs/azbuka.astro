              <span>Поддержка друзей</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#4894B2] mt-1">•</span>
              <span>Забота о близких</span>
            </li>
          </ul>
        </div>

        <!-- Навык 4 -->
        <div class="bg-gradient-to-br from-[#F2F7FD] to-white rounded-2xl p-8 hover:shadow-xl transition-all duration-300">
          <div class="text-5xl mb-4 text-center">🛡️</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 text-center">Личные границы</h3>
          <ul class="space-y-2 text-sm text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-[#4894B2] mt-1">•</span>
              <span>Выстраивание своих границ</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#4894B2] mt-1">•</span>
              <span>Уважение границ других</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#4894B2] mt-1">•</span>
              <span>Умение говорить "нет"</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[#4894B2] mt-1">•</span>
              <span>Защита своих интересов</span>
            </li>
          </ul>
        </div>

        <!-- Навык 5 -->
