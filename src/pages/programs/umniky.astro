<script>
  function openBookingModal(type?: string) {
    console.log('Opening booking modal for:', type || 'general');
    alert('Модальное окно записи будет здесь. Программа: Умники и умницы');
  }

  // Показать липкий футер при скролле
  window.addEventListener('scroll', () => {
    const footer = document.getElementById('stickyFooter');
    if (footer) {
      if (window.scrollY > 500) {
        footer.classList.remove('translate-y-full');
      } else {
        footer.classList.add('translate-y-full');
      }
    }
  });
</script>

