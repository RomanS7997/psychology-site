---
// src/pages/programs/umniky.astro
import Layout from '../../layouts/Layout.astro';
import ScrollAnimations from '../../components/ScrollAnimations.astro';
import AutoGallerySlider from '../../components/AutoGallerySlider.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SEO from '../../components/SEO.astro';
import FAQ from '../../components/FAQ.astro';

// Генерируем массив изображений для галереи (30 фото)
const galleryImages = Array.from({length: 30}, (_, i) => ({
  src: `/images/gallery/umniky/${i + 1}.jpg`,
  alt: `Занятие Умники и умницы - фото ${i + 1}`,
  caption: i % 4 === 0 ? 'Изучаем эмоции и чувства' : 
           i % 4 === 1 ? 'Ментальная арифметика и взаимодействие' : 
           i % 4 === 2 ? 'Творческое самовыражение' :
           'Работа в группе и общение'
}));
---

<SEO 
  title="Умники и умницы - Подготовка к школе в Одинцово | Для детей 5-7 лет"
  description="Программа Умники и умницы в Одинцово. Развитие эмоционального интеллекта для детей 5-7 лет. Умение общаться, дружить, понимать эмоции."
  keywords="подготовка к школе Одинцово, занятия для дошкольников, развитие детей 5-7 лет, занятия для детей Одинцово"
  schema="service"
/>

<Layout 
  title="Умники и умницы - Подготовка к школе в Одинцово | Для детей 5-7 лет"
  description="Психологический курс для детей 5-7 лет. Развитие эмоционального интеллекта, работа со страхами, навыки общения. Группы до 8 детей."
>

  



  <section class="relative pt-32 pb-20 overflow-hidden bg-gradient-to-br from-[#F2F7FD] via-white to-[#F2F7FD]" data-animate="fade">
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
      <div class="grid md:grid-cols-2 gap-12 items-center max-w-7xl mx-auto">
        
        <!-- Текст -->
        <div>
          <div class="inline-block px-4 py-2 bg-[#4894B2] text-white rounded-full font-semibold mb-4">
            Программа для детей 5-7 лет
          </div>
          
          <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-[#4894B2] to-[#18698F] bg-clip-text text-transparent">
            "Умники и умницы"
          </h1>
          
          <p class="text-2xl text-gray-700 mb-6 font-semibold">
            Подготовка к школе — легко и с удовольствием
          </p>

          <p class="text-lg text-gray-700 mb-8 leading-relaxed">
            Комплексно-развивающие занятия, где ребенок с помощью современных методик 
            учится читать, писать, считать, развивает память, речь и расширяет кругозор.
          </p>
          
          <div class="flex flex-wrap gap-4 mb-8">
            <button 
              onclick="openBookingModal()" 
              class="px-8 py-4 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full font-semibold transition shadow-lg hover:shadow-xl hover:scale-105"
            >
              Записаться на консультацию
            </button>
            <button 
              onclick="openBookingModal('specialist')" 
              class="px-8 py-4 bg-white hover:bg-[#F2F7FD] text-[#4894B2] border-2 border-[#4894B2] hover:border-[#18698F] rounded-full font-semibold transition"
            >
              Первичная консультация
            </button> 
          </div>
          
          <!-- Быстрые факты -->
          <div class="grid grid-cols-3 gap-6" data-stagger>
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4894B2] mb-2">5-7</div>
              <div class="text-sm text-gray-600">возраст</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4894B2] mb-2">4</div>
              <div class="text-sm text-gray-600">занятия/месяц</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4894B2] mb-2" data-counter="95" data-suffix="%">0</div>
              <div class="text-sm text-gray-600">улучшение поведения</div>
            </div>
          </div>
        </div>
        
          <!-- Изображение -->
        <div class="flex justify-center lg:justify-end " >
        <div class="relative w-full max-w-md">
          <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-2xl">
            <img 
              src="/psychology-site/images/gallery/umniky/47.jpg" 
              alt="Консультация психолога" 
              class="w-full h-auto"
            />
          
          <!-- Декоративные элементы -->
          <div class="absolute -top-6 -right-6 w-24 h-24 bg-[#F2F7FD] rounded-full opacity-30 blur-2xl"></div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-[#F2F7FD] rounded-full opacity-30 blur-2xl"></div>
        </div>
        
      </div>
    </div>
  </section>
<Breadcrumbs 
    items={[
      { label: 'Главная', href: '/' },
      { label: 'Программы', href: '/#programs' },
      { label: 'Умники и умницы' }
    ]}
  />
  </div><!-- 
  Что ребенок развивает -->
  <section class="py-20 bg-white" data-animate="slide-up">
    <div class="container mx-auto px-4 lg:px-8">
      <h2 class="text-4xl md:text-5xl font-bold text-center mb-4">
        Что будет изучать ваш ребенок
      </h2>
      <p class="text-center text-gray-600 text-lg mb-16 max-w-2xl mx-auto">
        Программа разработана с учетом требований ФГОС для подготовки к школе
      </p>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        
        <!-- Навык 1 -->
        <div class="bg-gradient-to-br from-[rgba(230,215,205,0.2)] via-[rgba(215,198,188,0.26)] to-[rgba(200,180,170,0.35)] rounded-3xl p-8 hover:shadow-xl transition">
          <div class="w-16 h-16 bg-[#4894B2] rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-3">Обучение чтению</h3>
          <p class="text-gray-700 leading-relaxed">
            От букв к словам и предложениям. Учим читать осмысленно, понимать прочитанное. 
            Скорость чтения к концу курса — 30-40 слов в минуту.
          </p>
        </div>

        <!-- Навык 2 -->
        <div class="bg-gradient-to-br from-[rgba(230,215,205,0.2)] via-[rgba(215,198,188,0.26)] to-[rgba(200,180,170,0.35)] rounded-3xl p-8 hover:shadow-xl transition">
          <div class="w-16 h-16 bg-[#4894B2] rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-3">Письмо и каллиграфия</h3>
          <p class="text-gray-700 leading-relaxed">
            Правильная постановка руки, графомоторные навыки. Учим писать буквы, 
            слоги и слова печатными и прописными буквами.
          </p>
        </div>

        <!-- Навык 3 -->
        <div class="bg-gradient-to-br from-[rgba(230,215,205,0.2)] via-[rgba(215,198,188,0.26)] to-[rgba(200,180,170,0.35)] rounded-3xl p-8 hover:shadow-xl transition">
          <div class="w-16 h-16 bg-[#4894B2] rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-3">Математика и логика</h3>
          <p class="text-gray-700 leading-relaxed">
            Счет до 100, состав числа, простые примеры и задачи. Развиваем 
            логическое мышление, учим анализировать и решать задачи.
          </p>
        </div>

        <!-- Навык 4 -->
        <div class="bg-gradient-to-br from-[rgba(230,215,205,0.2)] via-[rgba(215,198,188,0.26)] to-[rgba(200,180,170,0.35)] rounded-3xl p-8 hover:shadow-xl transition">
          <div class="w-16 h-16 bg-[#4894B2] rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-3">Окружающий мир</h3>
          <p class="text-gray-700 leading-relaxed">
            Расширяем кругозор: времена года, животные, растения, профессии. 
            Формируем представления о мире и обществе.
          </p>
        </div>

        <!-- Навык 5 -->
        <div class="bg-gradient-to-br from-[rgba(230,215,205,0.2)] via-[rgba(215,198,188,0.26)] to-[rgba(200,180,170,0.35)] rounded-3xl p-8 hover:shadow-xl transition">
          <div class="w-16 h-16 bg-[#4894B2] rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-3">Развитие речи</h3>
          <p class="text-gray-700 leading-relaxed">
            Учим выражать мысли, составлять рассказы, пересказывать. 
            Расширяем словарный запас, работаем над дикцией.
          </p>
        </div>

        <!-- Навык 6 -->
        <div class="bg-gradient-to-br from-[rgba(230,215,205,0.2)] via-[rgba(215,198,188,0.26)] to-[rgba(200,180,170,0.35)] rounded-3xl p-8 hover:shadow-xl transition">
          <div class="w-16 h-16 bg-[#4894B2] rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-3">Память и внимание</h3>
          <p class="text-gray-700 leading-relaxed">
            Тренируем все виды памяти и внимания. Учим концентрироваться, 
            запоминать и воспроизводить информацию.
          </p>
        </div>
        
      </div>

      <!-- Особенность программы -->
      <div class="mt-16 bg-gradient-to-r from-[#4894B2] to-[#18698F] rounded-3xl p-10 text-white text-center max-w-4xl mx-auto">
        <div class="text-5xl mb-4">✨</div>
        <h3 class="text-3xl font-bold mb-4">Особенность программы</h3>
        <p class="text-xl opacity-90">
          Мы не просто учим читать и считать — мы формируем учебную мотивацию и психологическую 
          готовность к школе. Ребенок научится самостоятельно работать, слушать педагога и 
          взаимодействовать с другими детьми.
        </p>
      </div>
    </div>
  </section>
  <!-- НОВАЯ ГАЛЕРЕЯ: Автослайдер с 30 фото -->
  <AutoGallerySlider 
    images={galleryImages}
    title="Как проходят наши занятия"
    subtitle="Смотрите, как дети учатся понимать эмоции и общаться друг с другом"
    accentColor="pink"
    autoplayDelay={4500}
  />
  <!-- Результаты программы -->
  <section class="py-20 bg-gradient-to-br from-[rgba(230,215,205,0.2)] via-[rgba(215,198,188,0.26)] to-[rgba(200,180,170,0.35)]" data-animate="fade">
    <div class="container mx-auto px-4 lg:px-8">
      <h2 class="text-4xl md:text-5xl font-bold text-center mb-4">
        Результаты программы
      </h2>
      <p class="text-center text-gray-600 text-lg mb-16 max-w-2xl mx-auto">
        Как меняются дети после курса "Умники и умницы"
      </p>
      
      <!-- Статистика -->
      <div class="grid md:grid-cols-4 gap-8 mb-16 max-w-6xl mx-auto" data-stagger>
        
        <div class="bg-white rounded-2xl p-8 text-center shadow-lg">
          <div class="text-5xl font-bold text-[#4894B2] mb-2" data-counter="95" data-suffix="%">0</div>
          <div class="text-gray-700 font-semibold">Поступают в желаемые школы</div>
        </div>

        <div class="bg-white rounded-2xl p-8 text-center shadow-lg">
          <div class="text-5xl font-bold text-[#4894B2] mb-2" data-counter="100" data-suffix="%">0</div>
          <div class="text-gray-700 font-semibold">Слов в минуту читают</div>
        </div>

        <div class="bg-white rounded-2xl p-8 text-center shadow-lg">
          <div class="text-5xl font-bold text-[#4894B2] mb-2" data-counter="92" data-suffix="%">0</div>
          <div class="text-gray-700 font-semibold">Готовы к школьной нагрузке</div>
        </div>

        <div class="bg-white rounded-2xl p-8 text-center shadow-lg">
          <div class="text-5xl font-bold text-[#4894B2] mb-2">30-40</div>
          <div class="text-gray-700 font-semibold">Повысилась уверенность</div>
        </div>
        
      </div>

      <!-- Прогресс-бары -->
      <h3 class="text-3xl font-bold text-center mb-12">Средний прогресс после 6 месяцев</h3>
      
      <div class="max-w-4xl mx-auto space-y-6">
        
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <div class="flex items-center justify-between mb-3">
            <span class="font-bold text-gray-900">Навыки чтения</span>
            <span class="text-[#4894B2] font-bold">30% → 92%</span>
          </div>
          <div class="h-4 bg-gray-200 rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-br from-[#4894B2] to-[#18698F] rounded-full" data-progress-bar="92" style="width: 0%; transition-duration: 2s;"></div>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <div class="flex items-center justify-between mb-3">
            <span class="font-bold text-gray-900">Математические способности</span>
            <span class="text-[#4894B2] font-bold">20% → 85%</span>
          </div>
          <div class="h-4 bg-gray-200 rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-br from-[#4894B2] to-[#18698F] rounded-full" data-progress-bar="80" style="width: 0%; transition-duration: 2s;"></div>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <div class="flex items-center justify-between mb-3">
            <span class="font-bold text-gray-900">Концентрация внимания</span>
            <span class="text-[#4894B2] font-bold">35% → 30-40</span>
          </div>
          <div class="h-4 bg-gray-200 rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-br from-[#4894B2] to-[#18698F] rounded-full" data-progress-bar="88" style="width: 0%; transition-duration: 2s;"></div>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <div class="flex items-center justify-between mb-3">
            <span class="font-bold text-gray-900">Учебная мотивация</span>
            <span class="text-[#4894B2] font-bold">40% → 95%</span>
          </div>
          <div class="h-4 bg-gray-200 rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-br from-[#4894B2] to-[#18698F] rounded-full" data-progress-bar="95" style="width: 0%; transition-duration: 2s;"></div>
          </div>
        </div>
        
      </div>
    </div>
  </section>

  <!-- Расписание и формат -->
  <section class="py-20 bg-white" data-animate="slide-up">
    <div class="container mx-auto px-4 lg:px-8">
      <h2 class="text-4xl md:text-5xl font-bold text-center mb-16">
        Расписание и формат занятий
      </h2>
      
      <div class="grid md:grid-cols-2 gap-12 max-w-6xl mx-auto">
        
        <!-- Расписание -->
        <div class="bg-gradient-to-br from-[#4894B2] to-[#18698F] rounded-3xl p-10">
          <div class="text-6xl mb-6 text-center">📅</div>
          <h3 class="text-3xl font-bold text-white mb-6 text-center">Среда</h3>
          <p class="text-2xl text-center text-white font-bold mb-8">17:00 - 18:30</p>
          
          <div class="bg-white/70 backdrop-blur-sm rounded-2xl p-6">
            <h4 class="font-bold text-gray-900 mb-4">Формат занятий:</h4>
            <ul class="space-y-3">
              <li class="flex items-center gap-3">
                <span class="text-[#4894B2] text-xl">✓</span>
                <span><strong>Длительность:</strong> 90 минут (с перерывом)</span>
              </li>
              <li class="flex items-center gap-3">
                <span class="text-[#4894B2] text-xl">✓</span>
                <span><strong>Размер группы:</strong> до 8 детей</span>
              </li>
              <li class="flex items-center gap-3">
                <span class="text-[#4894B2] text-xl">✓</span>
                <span><strong>Возраст:</strong> 5-7 лет</span>
              </li>
              <li class="flex items-center gap-3">
                <span class="text-[#4894B2] text-xl">✓</span>
                <span><strong>Частота:</strong> 8 занятий в месяц</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Методы работы -->
        <div class="bg-gradient-to-br from-[rgba(230,215,205,0.2)] via-[rgba(215,198,188,0.26)] to-[rgba(200,180,170,0.35)] rounded-3xl p-10">
          <div class="text-6xl mb-6 text-center">🎭</div>
          <h3 class="text-3xl font-bold text-gray-900 mb-6 text-center">Методы работы</h3>
          
          <div class="space-y-6">
            <div class="bg-white/70 backdrop-blur-sm rounded-2xl p-6">
              <h4 class="font-bold text-gray-900 mb-2">Игротерапия</h4>
              <p class="text-gray-700">Проработка эмоций через игру и ролевые ситуации</p>
            </div>

            <div class="bg-white/70 backdrop-blur-sm rounded-2xl p-6">
              <h4 class="font-bold text-gray-900 mb-2">Методика Н. Зайцева</h4>
              <p class="text-gray-700">Выражение чувств через рисование и творчество</p>
            </div>

            <div class="bg-white/70 backdrop-blur-sm rounded-2xl p-6">
              <h4 class="font-bold text-gray-900 mb-2">Телесные практики</h4>
              <p class="text-gray-700">Релаксация, дыхательные упражнения, йога</p>
            </div>
          </div>
        </div>
        
      </div>
    </div>
  </section>

  <!-- Преподаватель -->
  <section class="py-20 bg-gradient-to-br from-[#4894B2] to-[#18698F]" data-animate="fade">
    <div class="container mx-auto px-4 lg:px-8">
      <h2 class="text-4xl md:text-5xl font-bold text-center mb-16 text-white">
        Кто будет вести занятия
