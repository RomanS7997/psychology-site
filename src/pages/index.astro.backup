---
// ПОЛНАЯ главная страница с ВСЕМИ блоками из плана
import Layout from '../layouts/Layout.astro';
import NewHero from '../components/NewHero.astro';
import SocialProof from '../components/global/SocialProof.astro';
import SEO from '../components/SEO.astro';
import FAQ from '../components/FAQ.astro';
---

<SEO 
  title="Психолог в Одинцово и Лесном городке | Консультации онлайн и офлайн"
  description="Психологический центр Юлии Ляпиной в Одинцово. Консультирование взрослых и детей, семейная терапия, развивающие программы. Записаться онлайн."
  keywords="психолог Одинцово, психолог Лесной городок, психотерапия, консультации онлайн, детский психолог"
  schema="organization"
/>

<Layout 
  title="Психолог в Одинцово и Лесном городке | Консультации онлайн и офлайн"
  description="Психологический центр Юлии Ляпиной в Одинцово. Консультирование взрослых и детей, семейная терапия, развивающие программы."
>
  <!-- БЛОК 1: Hero Section (уже готов, просто используем) -->
  <NewHero 
    title="Психологический центр Юлии Ляпиной"
    subtitle="Профессиональная психологическая помощь взрослым и детям. Семейная терапия и консультирование. Развивающие программы для детей 4-9 лет."
  />



  <!-- БЛОК 3: С чем мы поможем (9 карточек проблем) -->
  <section id="services" class="relative py-20">
    <div class="absolute inset-0 opacity-10" style="background-image: url('/images/watercolor-blue.jpg'); background-size: cover; background-position: center;"></div>
    
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
      <h2 class="text-4xl md:text-5xl font-bold text-center text-gray-900 mb-4">
        С какими запросами к нам обращаются
      </h2>
      <p class="text-center text-gray-600 text-lg mb-16 max-w-2xl mx-auto">
        Найдите себя в одной из ситуаций
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <!-- Карточка 1: Тревога -->
        <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100">
          <div class="text-5xl mb-4">😰</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Тревога и страхи</h3>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Панические атаки, постоянное беспокойство, необъяснимый страх
          </p>
          <button onclick="openBookingModal()" class="text-[#4894B2] hover:text-teal-700 font-semibold inline-flex items-center group">
            Как мы работаем
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>

        <!-- Карточка 2: Отношения -->
        <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100">
          <div class="text-5xl mb-4">💔</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Проблемы в отношениях</h3>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Конфликты с партнером, ревность, измена, развод
          </p>
          <button onclick="openBookingModal()" class="text-[#4894B2] hover:text-teal-700 font-semibold inline-flex items-center group">
            Семейная терапия
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>

        <!-- Карточка 3: Дети -->
        <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100">
          <div class="text-5xl mb-4">🧒</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Ребенок не слушается</h3>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Истерики, капризы, агрессия, проблемы с учебой
          </p>
          <button onclick="openBookingModal()" class="text-[#4894B2] hover:text-teal-700 font-semibold inline-flex items-center group">
            Детский психолог
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>

        <!-- Карточка 4: Самооценка -->
        <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100">
          <div class="text-5xl mb-4">😔</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Низкая самооценка</h3>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Неуверенность в себе, страх оценки, постоянное сравнение
          </p>
          <button onclick="openBookingModal()" class="text-[#4894B2] hover:text-teal-700 font-semibold inline-flex items-center group">
            Подробнее
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>

        <!-- Карточка 5: Кризисы -->
        <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100">
          <div class="text-5xl mb-4">🌪️</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Возрастной кризис</h3>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Потеря смысла, "что я делаю со своей жизнью?"
          </p>
          <button onclick="openBookingModal()" class="text-[#4894B2] hover:text-teal-700 font-semibold inline-flex items-center group">
            Как помогаем
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>

        <!-- Карточка 6: Подготовка к школе (с urgency) -->
        <div class="bg-gradient-to-br from-teal-50/90 to-blue-50/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border-2 border-teal-200 relative overflow-hidden">
          <div class="absolute top-4 right-4 bg-[#4894B2] text-white text-xs font-bold px-3 py-1 rounded-full animate-pulse">
            🔥 Осталось 2 места
          </div>
          <div class="text-5xl mb-4">🎓</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Подготовка к школе</h3>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Развивающие программы для детей 4-7 лет
          </p>
          <button onclick="openBookingModal()" class="text-[#4894B2] hover:text-teal-700 font-semibold inline-flex items-center group">
            Смотреть программы
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>

        <!-- Карточка 7: Депрессия -->
        <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100">
          <div class="text-5xl mb-4">🌧️</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Депрессия, апатия</h3>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Нет сил, нет желаний, все безразлично
          </p>
          <button onclick="openBookingModal()" class="text-[#4894B2] hover:text-teal-700 font-semibold inline-flex items-center group">
            Как выйти из депрессии
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>

        <!-- Карточка 8: Развод -->
        <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100">
          <div class="text-5xl mb-4">💍</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Развод и расставание</h3>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Как пережить развод, начать новую жизнь
          </p>
          <button onclick="openBookingModal()" class="text-[#4894B2] hover:text-teal-700 font-semibold inline-flex items-center group">
            Помощь при разводе
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>

        <!-- Карточка 9: Не нашли? -->
        <div class="bg-gradient-to-br from-teal-100/90 to-blue-100/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-teal-200">
          <div class="text-5xl mb-4">💬</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Не нашли свою ситуацию?</h3>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Опишите вашу проблему - мы поможем
          </p>
          <button 
            onclick="openBookingModal()"
            class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white font-semibold rounded-full transition-all duration-300 shadow-lg hover:shadow-xl hover:scale-105"
          >
            Бесплатная консультация
          </button>
        </div>

      </div>
    </div>
  </section>

  <!-- БЛОК 4: Видео-презентация центра -->
  <section class="py-20 bg-gradient-to-br from-blue-50 to-teal-50">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        
        <!-- Видео превью -->
        <div 
          class="relative aspect-video rounded-2xl overflow-hidden shadow-2xl bg-gray-900 cursor-pointer group"
          onclick="openVideoModal()"
        >
          <!-- Превью (первый кадр видео) -->
          <video 
            class="w-full h-full object-cover pointer-events-none"
            preload="metadata"
            muted
          >
            <source src="/videos/mainvid.mp4#t=0.1" type="video/mp4">
          </video>
          
          <!-- Оверлей с кнопкой Play -->
          <div class="absolute inset-0 bg-black bg-opacity-30 flex items-center justify-center transition-all duration-300 group-hover:bg-opacity-20">
            <button 
              class="w-24 h-24 bg-white bg-opacity-90 hover:bg-opacity-100 rounded-full flex items-center justify-center transition-all duration-300 group-hover:scale-110 shadow-2xl"
              aria-label="Воспроизвести видео"
            >
              <svg class="w-12 h-12 text-[#4894B2] ml-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>
          </div>
        </div>
        
        <!-- Текст -->
        <div>
          <h2 class="text-4xl font-bold mb-6 text-gray-900">
            Добро пожаловать в психологический центр Юлии Ляпиной
          </h2>
          <p class="text-lg mb-4 text-gray-700">
            Мы помогаем людям более 10 лет. За это время через наш центр прошли более 500 клиентов.
          </p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-center gap-2 text-gray-700">
              <span class="text-[#4894B2]">✓</span>
              Индивидуальный подход к каждому клиенту
            </li>
            <li class="flex items-center gap-2 text-gray-700">
              <span class="text-[#4894B2]">✓</span>
              Современные научно-обоснованные методы
            </li>
            <li class="flex items-center gap-2 text-gray-700">
              <span class="text-[#4894B2]">✓</span>
              Комфортная атмосфера и конфиденциальность
            </li>
            <li class="flex items-center gap-2 text-gray-700">
              <span class="text-[#4894B2]">✓</span>
              Онлайн и офлайн консультации
            </li>
          </ul>
          <button onclick="openBookingModal()" class="px-8 py-4 bg-[#4894B2] hover:bg-[#18698F] text-white font-semibold rounded-full transition shadow-lg">
            Записаться на консультацию
          </button>
        </div>
        
      </div>
    </div>
  </section>

  <!-- БЛОК 5: Развивающие программы для детей -->
  <section id="programs" class="py-20 bg-white">
    <div class="container mx-auto px-4 lg:px-8">
      <h2 class="text-4xl md:text-5xl font-bold text-center text-gray-900 mb-4">
        Развивающие программы для детей 4-9 лет
      </h2>
      <p class="text-center text-gray-600 text-lg mb-16">
        Готовим к школе • Развиваем эмоциональный интеллект • Учим общаться
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        
        <!-- Программа 1: Умники и умницы -->
        <div class="bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100 relative overflow-hidden group">
          <!-- Urgency banner -->
          <div class="bg-gradient-to-r from-red-500 to-pink-500 text-white text-center py-2 text-sm font-bold flex items-center justify-center gap-2">
            <span class="inline-block w-2 h-2 bg-white rounded-full animate-pulse"></span>
            Осталось <strong>2 места</strong> в группе
          </div>
          
          <div class="p-6">
            <div class="text-5xl mb-4">🧠</div>
            <h3 class="text-2xl font-bold text-gray-900 mb-2">Умники и умницы</h3>
            <p class="text-gray-600 mb-4">Возраст: 4-7 лет</p>
            
            <ul class="space-y-2 mb-6">
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-[#4894B2] mt-0.5">✓</span>
                <span>Развитие логики и мышления</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-[#4894B2] mt-0.5">✓</span>
                <span>Подготовка к школе</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-[#4894B2] mt-0.5">✓</span>
                <span>Творческие задания</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-[#4894B2] mt-0.5">✓</span>
                <span>Работа в группе (до 8 детей)</span>
              </li>
            </ul>
            
            <div class="bg-[#F2F7FD] p-4 rounded-lg mb-4">
              <p class="text-sm text-[#4894B2]">
                <strong>95% выпускников</strong> успешно поступили в желаемую школу
              </p>
            </div>
            
            <div class="flex items-center justify-between mb-4">
              <span class="text-2xl font-bold text-[#4894B2]">3 500₽/мес</span>
              <span class="text-sm text-gray-500">8 занятий</span>
            </div>
            
            <button 
              onclick="openBookingModal()"
              class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white font-semibold rounded-full transition-all duration-300 shadow-lg hover:shadow-xl group-hover:scale-105"
            >
              Записаться в группу
            </button>
            
            <p class="text-xs text-center mt-2 text-gray-500">
              Начало занятий: 1 февраля
            </p>
          </div>
        </div>

        <!-- Программа 2: Азбука общения -->
        <div class="bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100 relative overflow-hidden group">
          <div class="bg-[#F2F7FD] text-gray-800 text-center py-2 text-sm font-bold flex items-center justify-center gap-2">
            <span class="inline-block w-2 h-2 bg-[#F2F7FD] rounded-full animate-pulse"></span>
            Набор открыт
          </div>
          
          <div class="p-6">
            <div class="text-5xl mb-4">💬</div>
            <h3 class="text-2xl font-bold text-gray-900 mb-2">Азбука общения</h3>
            <p class="text-gray-600 mb-4">Возраст: 5-9 лет</p>
            
            <ul class="space-y-2 mb-6">
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-[#4894B2] mt-0.5">✓</span>
                <span>Эмоциональный интеллект</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-[#4894B2] mt-0.5">✓</span>
                <span>Навыки общения</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-[#4894B2] mt-0.5">✓</span>
                <span>Уверенность в себе</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-[#4894B2] mt-0.5">✓</span>
                <span>Ролевые игры</span>
              </li>
            </ul>
            
            <div class="bg-[#F2F7FD] p-4 rounded-lg mb-4">
              <p class="text-sm text-[#4894B2]">
                <strong>88% родителей</strong> отмечают улучшение поведения ребенка
              </p>
            </div>
            
            <div class="flex items-center justify-between mb-4">
              <span class="text-2xl font-bold text-[#4894B2]">2 800₽/мес</span>
              <span class="text-sm text-gray-500">4 занятия</span>
            </div>
            
            <button 
              onclick="openBookingModal()"
              class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white font-semibold rounded-full transition-all duration-300 shadow-lg hover:shadow-xl group-hover:scale-105"
            >
              Записаться на пробное занятие
            </button>
            
            <p class="text-xs text-center mt-2 text-gray-500">
              Среда, 18:30
            </p>
          </div>
        </div>

        <!-- Программа 3: Подготовка к школе -->
        <div class="bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100 relative overflow-hidden group">
          <div class="h-10"></div>
          
          <div class="p-6">
            <div class="text-5xl mb-4">📖</div>
            <h3 class="text-2xl font-bold text-gray-900 mb-2">Подготовка к школе</h3>
            <p class="text-gray-600 mb-4">Возраст: 6-7 лет</p>
            
            <ul class="space-y-2 mb-6">
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-[#4894B2] mt-0.5">✓</span>
                <span>Чтение и письмо</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-[#4894B2] mt-0.5">✓</span>
                <span>Математика и счет</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-[#4894B2] mt-0.5">✓</span>
                <span>Окружающий мир</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-[#4894B2] mt-0.5">✓</span>
                <span>Концентрация внимания</span>
              </li>
            </ul>
            
            <div class="bg-[#F2F7FD] p-4 rounded-lg mb-4">
              <p class="text-sm text-[#4894B2]">
                <strong>100% выпускников</strong> готовы к первому классу
              </p>
            </div>
            
            <div class="flex items-center justify-between mb-4">
              <span class="text-2xl font-bold text-[#4894B2]">4 200₽/мес</span>
              <span class="text-sm text-gray-500">8 занятий</span>
            </div>
            
            <button 
              onclick="openBookingModal()"
              class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white font-semibold rounded-full transition-all duration-300 shadow-lg hover:shadow-xl group-hover:scale-105"
            >
              Узнать подробности
            </button>
          </div>
        </div>

      </div>

      <!-- CTA под программами -->
      <div class="text-center mt-12">
        <p class="text-lg mb-4 text-gray-700">
          Не знаете какая программа подойдет вашему ребенку?
        </p>
        <a href="/test/children" class="inline-block px-8 py-4 bg-white hover:bg-gray-50 text-[#4894B2] font-semibold rounded-full transition-all border-2 border-teal-600 shadow-md">
          📋 Пройти бесплатный тест (скидка 10%)
        </a>
      </div>
    </div>
  </section>

  <!-- БЛОК 6: Почему выбирают нас -->
