---
// src/pages/test/general.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Бесплатный психологический тест - Психологический центр"
  description="Пройдите бесплатный тест и получите рекомендации от психолога. Скидка 10% на первую консультацию!"
>

  <section class="min-h-screen py-24 bg-gradient-to-br from-teal-50 via-blue-50 to-purple-50">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-3xl mx-auto">
        
        <!-- Прогресс-бар -->
        <div class="mb-8">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-semibold text-gray-700">Шаг <span id="current-step">1</span> из <span id="total-steps">5</span></span>
            <span class="text-sm font-semibold text-[#4894B2]"><span id="progress-percent">0</span>%</span>
          </div>
          <div class="w-full h-3 bg-gray-200 rounded-full overflow-hidden">
            <div id="progress-bar" class="h-full bg-gradient-to-r from-[#4894B2] to-[#18698F] rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
        </div>

        <!-- Форма теста -->
        <div class="bg-white rounded-3xl shadow-2xl p-8 md:p-12">
          
          <!-- Шаг 0: Приветствие -->
          <div class="step active" data-step="0">
            <div class="text-center mb-8">
              <div class="text-7xl mb-6">🧠</div>
              <h1 class="text-4xl font-bold text-gray-900 mb-4">
                Бесплатный психологический тест
              </h1>
              <p class="text-xl text-gray-700 mb-6">
                Узнайте, что вас беспокоит, и получите рекомендации психолога
              </p>
              
              <!-- Скидка -->
              <div class="bg-gradient-to-r from-teal-100 to-blue-100 border-2 border-teal-300 rounded-2xl p-6 mb-8">
                <div class="text-3xl mb-2">🎁</div>
                <p class="text-lg font-bold text-teal-900 mb-2">
                  Специальное предложение!
                </p>
                <p class="text-teal-800">
                  Пройдите тест и получите <strong>скидку 10%</strong> на первую консультацию
                </p>
              </div>

              <div class="text-left bg-gray-50 rounded-xl p-6 mb-8">
                <p class="text-gray-700 mb-4">
                  <strong>Тест займёт всего 2-3 минуты</strong> и поможет:
                </p>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start gap-2">
                    <span class="text-[#4894B2] mt-1">✓</span>
                    <span>Определить, с чем вы столкнулись</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-[#4894B2] mt-1">✓</span>
                    <span>Понять степень ситуации</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-[#4894B2] mt-1">✓</span>
                    <span>Получить персональные рекомендации</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-[#4894B2] mt-1">✓</span>
                    <span>Подобрать подходящего специалиста</span>
                  </li>
                </ul>
              </div>

              <p class="text-sm text-gray-500 mb-6">
                Все ответы конфиденциальны и используются только для подбора рекомендаций
              </p>
            </div>

            <button data-action="next" class="w-full px-8 py-4 bg-gradient-to-r from-[#4894B2] to-[#18698F] hover:from-teal-700 hover:to-blue-700 text-white rounded-full font-bold transition shadow-lg hover:shadow-xl text-lg">
              Начать тест
            </button>
          </div>

          <!-- Шаг 1: Что беспокоит -->
          <div class="step" data-step="1">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Что вас беспокоит больше всего?</h2>
            
            <div class="space-y-3">
              <label class="answer-option block">
                <input type="radio" name="concern" value="anxiety" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">😰 Тревога и страхи</div>
                  <div class="text-sm text-gray-600">Постоянное беспокойство, панические атаки, фобии</div>
                </div>
              </label>
              
              <label class="answer-option block">
                <input type="radio" name="concern" value="depression" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">😔 Депрессия и апатия</div>
                  <div class="text-sm text-gray-600">Потеря интереса к жизни, грусть, нет сил</div>
                </div>
              </label>
              
              <label class="answer-option block">
                <input type="radio" name="concern" value="relationships" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">💔 Проблемы в отношениях</div>
                  <div class="text-sm text-gray-600">Конфликты с партнёром, семьёй, друзьями</div>
                </div>
              </label>

              <label class="answer-option block">
                <input type="radio" name="concern" value="stress" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">🔥 Стресс и выгорание</div>
                  <div class="text-sm text-gray-600">Переутомление, нет энергии, эмоциональное истощение</div>
                </div>
              </label>

              <label class="answer-option block">
                <input type="radio" name="concern" value="self-esteem" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">🪞 Низкая самооценка</div>
                  <div class="text-sm text-gray-600">Неуверенность в себе, самокритика, комплексы</div>
                </div>
              </label>

              <label class="answer-option block">
                <input type="radio" name="concern" value="trauma" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">💥 Травматический опыт</div>
                  <div class="text-sm text-gray-600">Последствия тяжёлых событий, потерь, насилия</div>
                </div>
              </label>

              <label class="answer-option block">
                <input type="radio" name="concern" value="other" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">🤔 Другое</div>
                  <div class="text-sm text-gray-600">Хочу разобраться в себе, личностный рост</div>
                </div>
              </label>
            </div>

            <div class="flex gap-4 mt-8">
              <button data-action="prev" class="flex-1 px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-full font-semibold transition">
                Назад
              </button>
              <button data-action="next" class="flex-1 px-8 py-3 bg-gradient-to-r from-[#4894B2] to-[#18698F] hover:from-teal-700 hover:to-blue-700 text-white rounded-full font-bold transition shadow-lg">
                Далее
              </button>
            </div>
          </div>

          <!-- Шаг 2: Как долго беспокоит -->
          <div class="step" data-step="2">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Как долго вас это беспокоит?</h2>
            
            <div class="space-y-3">
              <label class="answer-option block">
                <input type="radio" name="duration" value="recent" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">Недавно (до 1 месяца)</div>
                  <div class="text-sm text-gray-600">Это началось совсем недавно</div>
                </div>
              </label>
              
              <label class="answer-option block">
                <input type="radio" name="duration" value="months" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">Несколько месяцев (1-6 месяцев)</div>
                  <div class="text-sm text-gray-600">Уже какое-то время меня это беспокоит</div>
                </div>
              </label>
              
              <label class="answer-option block">
                <input type="radio" name="duration" value="year" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">Больше года</div>
                  <div class="text-sm text-gray-600">Это длится уже давно</div>
                </div>
              </label>

              <label class="answer-option block">
                <input type="radio" name="duration" value="always" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">Всю жизнь или очень давно</div>
                  <div class="text-sm text-gray-600">Я помню это с детства / очень давно</div>
                </div>
              </label>
            </div>

            <div class="flex gap-4 mt-8">
              <button data-action="prev" class="flex-1 px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-full font-semibold transition">
                Назад
              </button>
              <button data-action="next" class="flex-1 px-8 py-3 bg-gradient-to-r from-[#4894B2] to-[#18698F] hover:from-teal-700 hover:to-blue-700 text-white rounded-full font-bold transition shadow-lg">
                Далее
              </button>
            </div>
          </div>

          <!-- Шаг 3: Степень влияния на жизнь -->
          <div class="step" data-step="3">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Насколько это влияет на вашу жизнь?</h2>
            
            <div class="space-y-3">
              <label class="answer-option block">
                <input type="radio" name="severity" value="low" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">😊 Слегка беспокоит</div>
                  <div class="text-sm text-gray-600">Могу справляться, но хочу улучшить ситуацию</div>
                </div>
              </label>
              
              <label class="answer-option block">
                <input type="radio" name="severity" value="medium" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">😐 Заметно мешает</div>
                  <div class="text-sm text-gray-600">Влияет на работу, отношения или самочувствие</div>
                </div>
              </label>
              
              <label class="answer-option block">
                <input type="radio" name="severity" value="high" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">😟 Сильно мешает жить</div>
                  <div class="text-sm text-gray-600">Трудно справляться, снижает качество жизни</div>
                </div>
              </label>

              <label class="answer-option block">
                <input type="radio" name="severity" value="critical" class="hidden">
                <div class="answer-card p-4 border-2 border-gray-200 rounded-xl cursor-pointer transition hover:border-teal-400 hover:bg-[#F2F7FD]">
                  <div class="font-semibold mb-1">😰 Критическая ситуация</div>
                  <div class="text-sm text-gray-600">Не могу справиться самостоятельно, нужна срочная помощь</div>
                </div>
              </label>
            </div>

            <div class="flex gap-4 mt-8">
              <button data-action="prev" class="flex-1 px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-full font-semibold transition">
                Назад
              </button>
              <button data-action="next" class="flex-1 px-8 py-3 bg-gradient-to-r from-[#4894B2] to-[#18698F] hover:from-teal-700 hover:to-blue-700 text-white rounded-full font-bold transition shadow-lg">
                Далее
              </button>
            </div>
          </div>

          <!-- Шаг 4: Контактные данные -->
          <div class="step" data-step="4">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Ваши контактные данные</h2>
            <p class="text-gray-600 mb-6">
              Мы свяжемся с вами и расскажем о рекомендациях на основе ваших ответов
            </p>
            
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Ваше имя *</label>
                <input 
                  type="text" 
                  id="user-name"
                  required
                  class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-teal-500 focus:outline-none transition"
                  placeholder="Как к вам обращаться?"
                >
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Телефон *</label>
                <input 
                  type="tel" 
                  id="user-phone"
                  required
                  class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-teal-500 focus:outline-none transition"
                  placeholder="+7 (___) ___-__-__"
                >
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Email (необязательно)</label>
                <input 
                  type="email" 
                  id="user-email"
                  class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-teal-500 focus:outline-none transition"
                  placeholder="your@email.com"
                >
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Комментарий (необязательно)</label>
                <textarea 
                  id="user-comment"
                  rows="3"
                  class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-teal-500 focus:outline-none transition resize-none"
                  placeholder="Если хотите что-то добавить..."
                ></textarea>
              </div>
            </div>

            <div class="flex gap-4 mt-8">
              <button data-action="prev" class="flex-1 px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-full font-semibold transition">
                Назад
              </button>
              <button data-action="submit" class="flex-1 px-8 py-3 bg-gradient-to-r from-[#4894B2] to-[#18698F] hover:from-teal-700 hover:to-blue-700 text-white rounded-full font-bold transition shadow-lg">
                Получить рекомендации
              </button>
            </div>
          </div>

          <!-- Шаг 5: Финальный экран -->
          <div class="step" data-step="5">
            <div class="text-center">
              <div class="text-7xl mb-6">🎉</div>
              <h2 class="text-3xl font-bold text-gray-900 mb-4">
                Спасибо за прохождение теста!
              </h2>
              <p class="text-xl text-gray-700 mb-8">
                Мы свяжемся с вами в течение 15 минут и дадим персональные рекомендации
              </p>

              <div class="bg-gradient-to-r from-teal-100 to-blue-100 rounded-2xl p-6 mb-8">
                <p class="text-lg font-bold text-teal-900 mb-2">
                  Ваша скидка 10% активирована! 🎁
                </p>
                <p class="text-teal-800">
                  Не забудьте упомянуть промокод <strong>TEST10</strong> при записи
                </p>
              </div>

              <div class="text-left bg-gray-50 rounded-xl p-6 mb-8">
                <p class="font-semibold text-gray-900 mb-4">Что дальше?</p>
                <ul class="space-y-3 text-gray-700">
                  <li class="flex items-start gap-3">
                    <span class="text-2xl">1️⃣</span>
                    <span>Наш психолог свяжется с вами по телефону</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-2xl">2️⃣</span>
                    <span>Расскажет о рекомендациях на основе ваших ответов</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-2xl">3️⃣</span>
                    <span>Подберём подходящего специалиста</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-2xl">4️⃣</span>
                    <span>Запишем вас на удобное время</span>
                  </li>
                </ul>
              </div>

              <div class="flex flex-col sm:flex-row gap-4">
                <a href="/psychology-site/" class="flex-1 px-8 py-3 bg-gradient-to-r from-[#4894B2] to-[#18698F] hover:from-teal-700 hover:to-blue-700 text-white rounded-full font-bold transition shadow-lg text-center">
                  Вернуться на главную
                </a>
                <a href="/psychology-site/specialists" class="flex-1 px-8 py-3 bg-white hover:bg-gray-50 text-[#4894B2] border-2 border-[#4894B2] rounded-full font-bold transition text-center">
                  Наши специалисты
                </a>
              </div>
            </div>
          </div>

        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  .step {
    display: none;
  }
  
  .step.active {
    display: block;
    animation: fadeIn 0.5s ease-in-out;
  }
  
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .answer-option input:checked + .answer-card {
    @apply border-[#4894B2] bg-[#F2F7FD];
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    let currentStep = 0;
    const totalSteps = 5;
    const testData = {};

    function updateProgress() {
      const percent = Math.round((currentStep / totalSteps) * 100);
      document.getElementById('progress-bar').style.width = percent + '%';
      document.getElementById('progress-percent').textContent = percent;
      document.getElementById('current-step').textContent = currentStep + 1;
      document.getElementById('total-steps').textContent = totalSteps + 1;
    }

    function nextStep() {
      const currentStepEl = document.querySelector(`.step[data-step="${currentStep}"]`);
      const selectedAnswer = currentStepEl?.querySelector('input[type="radio"]:checked');
      
      if (currentStep > 0 && currentStep < 4 && !selectedAnswer) {
        alert('Пожалуйста, выберите ответ');
        return;
      }
      
      if (selectedAnswer) {
        testData[selectedAnswer.name] = selectedAnswer.value;
      }
      
      document.querySelector(`.step[data-step="${currentStep}"]`)?.classList.remove('active');
      currentStep++;
      document.querySelector(`.step[data-step="${currentStep}"]`)?.classList.add('active');
      
      updateProgress();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function prevStep() {
      document.querySelector(`.step[data-step="${currentStep}"]`)?.classList.remove('active');
      currentStep--;
      document.querySelector(`.step[data-step="${currentStep}"]`)?.classList.add('active');
      
      updateProgress();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function submitTest() {
      const name = document.getElementById('user-name')?.value;
      const phone = document.getElementById('user-phone')?.value;
      const email = document.getElementById('user-email')?.value;
      const comment = document.getElementById('user-comment')?.value;
      
      if (!name || !phone) {
        alert('Пожалуйста, заполните обязательные поля');
        return;
      }
      
      testData.name = name;
      testData.phone = phone;
      testData.email = email;
      testData.comment = comment;
      
      console.log('Test data:', testData);
      nextStep();
    }

    // Добавляем обработчики на все кнопки
    document.querySelectorAll('[data-action="next"]').forEach(btn => {
      btn.addEventListener('click', nextStep);
    });
    
    document.querySelectorAll('[data-action="prev"]').forEach(btn => {
      btn.addEventListener('click', prevStep);
    });
    
    document.querySelectorAll('[data-action="submit"]').forEach(btn => {
      btn.addEventListener('click', submitTest);
    });

    updateProgress();
  });
</script>
