---
// src/pages/reviews.astro
import Layout from '../layouts/Layout.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<Layout 
  title="Отзывы клиентов | Кабинет психолога Ляпина Юлия"
  description="Реальные отзывы наших клиентов о работе с психологами центра. Более 500 довольных клиентов."
>
  <Breadcrumbs 
    items={[
      { label: 'Главная', href: '/' },
      { label: 'Отзывы' }
    ]}
  />

  <!-- Hero -->
  <section class="py-16 bg-gradient-to-br from-gray-50 to-white" data-animate="fade">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900">
          Отзывы наших клиентов
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Нам доверяют свое психологическое здоровье и развитие детей
        </p>
        
        <!-- Статистика -->
        <div class="grid grid-cols-3 gap-8 max-w-2xl mx-auto mb-12">
          <div>
            <div class="text-4xl font-bold text-[#4894B2] mb-2">500+</div>
            <div class="text-sm text-gray-600">Довольных клиентов</div>
          </div>
          <div>
            <div class="text-4xl font-bold text-[#4894B2] mb-2">4.9</div>
            <div class="text-sm text-gray-600">Средняя оценка</div>
          </div>
          <div>
            <div class="text-4xl font-bold text-[#4894B2] mb-2" data-counter="98" data-suffix="%">0</div>
            <div class="text-sm text-gray-600">Рекомендаций</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Отзывы -->
  <section class="py-16 bg-white" data-animate="slide-up">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-5xl mx-auto space-y-8">
        
        <!-- Отзыв 1 -->
        <div class="bg-gradient-to-br from-primary-light to-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-full bg-[#4894B2] flex items-center justify-center text-white text-xl font-bold flex-shrink-0">
              А
            </div>
            <div>
              <div class="font-bold text-gray-900 text-lg">Анна</div>
              <div class="text-sm text-gray-500">Консультирование взрослых</div>
              <div class="flex gap-1 mt-1">
                {[...Array(5)].map(() => (
                  <svg class="w-5 h-5 text-[#4894B2]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                  </svg>
                ))}
              </div>
            </div>
          </div>
          <p class="text-gray-700 leading-relaxed">
            Обратилась к психологу с паническими атаками. После 10 сессий жизнь стала совершенно другой! 
            Научилась справляться с тревогой, поняла причины своего состояния. Очень благодарна специалисту 
            за профессионализм и деликатность. Рекомендую всем, кто столкнулся с подобными проблемами.
          </p>
          <div class="mt-4 text-sm text-gray-500">3 недели назад</div>
        </div>

        <!-- Отзыв 2 -->
        <div class="bg-gradient-to-br from-primary-light to-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-full bg-[#4894B2] flex items-center justify-center text-white text-xl font-bold flex-shrink-0">
              М
            </div>
            <div>
              <div class="font-bold text-gray-900 text-lg">Мария</div>
              <div class="text-sm text-gray-500">Умники и умницы</div>
              <div class="flex gap-1 mt-1">
                {[...Array(5)].map(() => (
                  <svg class="w-5 h-5 text-[#4894B2]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                  </svg>
                ))}
              </div>
            </div>
          </div>
          <p class="text-gray-700 leading-relaxed">
            Сын ходит на программу "Умники и умницы" уже 4 месяца. Результат превзошел все ожидания! 
            Научился читать, считать, стал более усидчивым и внимательным. Педагоги находят подход 
            к каждому ребенку. В школу идем подготовленными и уверенными. Спасибо огромное!
          </p>
          <div class="mt-4 text-sm text-gray-500">1 месяц назад</div>
        </div>

        <!-- Отзыв 3 -->
        <div class="bg-gradient-to-br from-primary-light to-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-full bg-[#4894B2] flex items-center justify-center text-white text-xl font-bold flex-shrink-0">
              Е
            </div>
            <div>
              <div class="font-bold text-gray-900 text-lg">Елена</div>
              <div class="text-sm text-gray-500">Консультирование детей</div>
              <div class="flex gap-1 mt-1">
                {[...Array(5)].map(() => (
                  <svg class="w-5 h-5 text-[#4894B2]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                  </svg>
                ))}
              </div>
            </div>
          </div>
          <p class="text-gray-700 leading-relaxed">
            У дочери были сильные страхи и истерики. Детский психолог помог разобраться в ситуации 
            всего за несколько сессий. Работа велась в игровой форме, ребенок шел на встречи с радостью. 
            Сейчас дочка стала спокойнее, увереннее в себе. Очень рады, что обратились именно сюда!
          </p>
          <div class="mt-4 text-sm text-gray-500">2 месяца назад</div>
        </div>

        <!-- Отзыв 4 -->
        <div class="bg-gradient-to-br from-primary-light to-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-full bg-[#4894B2] flex items-center justify-center text-white text-xl font-bold flex-shrink-0">
              Д
            </div>
            <div>
              <div class="font-bold text-gray-900 text-lg">Дмитрий</div>
              <div class="text-sm text-gray-500">Семейное консультирование</div>
              <div class="flex gap-1 mt-1">
                {[...Array(5)].map(() => (
                  <svg class="w-5 h-5 text-[#4894B2]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                  </svg>
                ))}
              </div>
            </div>
          </div>
          <p class="text-gray-700 leading-relaxed">
            С женой были на грани развода. Решили попробовать семейную терапию. Это было непросто, 
            но психолог помог нам услышать друг друга, понять истинные причины конфликтов. Сейчас 
            наши отношения стали крепче чем когда-либо. Спасибо за спасение нашей семьи!
          </p>
          <div class="mt-4 text-sm text-gray-500">1 неделю назад</div>
        </div>

        <!-- Отзыв 5 -->
        <div class="bg-gradient-to-br from-primary-light to-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-full bg-[#4894B2] flex items-center justify-center text-white text-xl font-bold flex-shrink-0">
              О
            </div>
            <div>
              <div class="font-bold text-gray-900 text-lg">Ольга</div>
              <div class="text-sm text-gray-500">Азбука общения</div>
              <div class="flex gap-1 mt-1">
                {[...Array(5)].map(() => (
                  <svg class="w-5 h-5 text-[#4894B2]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                  </svg>
                ))}
              </div>
            </div>
          </div>
          <p class="text-gray-700 leading-relaxed">
            Дочь была очень застенчивой, сложно заводила друзей. После программы "Азбука общения" 
            ребенок преобразился! Научилась понимать свои эмоции, выражать чувства, общаться со 
            сверстниками. Появились друзья в садике. Огромное спасибо педагогам за их труд и заботу!
          </p>
          <div class="mt-4 text-sm text-gray-500">3 недели назад</div>
        </div>

        <!-- Отзыв 6 -->
        <div class="bg-gradient-to-br from-primary-light to-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-full bg-[#4894B2] flex items-center justify-center text-white text-xl font-bold flex-shrink-0">
              С
            </div>
            <div>
              <div class="font-bold text-gray-900 text-lg">Сергей</div>
              <div class="text-sm text-gray-500">Консультирование взрослых</div>
              <div class="flex gap-1 mt-1">
                {[...Array(5)].map(() => (
                  <svg class="w-5 h-5 text-[#4894B2]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                  </svg>
                ))}
              </div>
            </div>
          </div>
          <p class="text-gray-700 leading-relaxed">
            Долго не мог решиться обратиться к психологу. Теперь жалею только о потерянном времени! 
            Работа с прокрастинацией и поиском мотивации дала невероятные результаты. Психолог помогла 
            найти новые цели, понять себя. Жизнь снова обрела краски. Всем рекомендую!
          </p>
          <div class="mt-4 text-sm text-gray-500">2 недели назад</div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-[#4894B2] to-[#18698F]" data-animate="fade">
    <div class="container mx-auto px-4 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Станьте одним из моих довольных клиентов
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Запишитесь на консультацию и начните путь к изменениям уже сегодня
      </p>
      <button 
        onclick="openBookingModal()"
        class="px-12 py-5 bg-white hover:bg-gray-100 text-[#4894B2] rounded-full font-bold transition-colors shadow-xl text-lg"
      >
        Записаться на консультацию
      </button>
    </div>
  </section>

  <!-- Ссылки на внешние отзывы -->
  <section class="py-16 bg-white" data-animate="slide-up">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h3 class="text-2xl font-bold mb-8 text-gray-900">
          Читайте отзывы на независимых платформах
        </h3>
        <div class="flex flex-wrap gap-6 justify-center">
          <a 
            href="#" 
            class="flex items-center gap-3 px-8 py-4 bg-gray-50 hover:bg-primary-light rounded-xl transition-colors"
            target="_blank"
            rel="noopener"
          >
            <span class="text-2xl">⭐</span>
            <div class="text-left">
              <div class="font-bold text-gray-900">Яндекс.Карты</div>
              <div class="text-sm text-gray-600">4.9 / 5.0</div>
            </div>
          </a>
          
          <a 
            href="#" 
            class="flex items-center gap-3 px-8 py-4 bg-gray-50 hover:bg-primary-light rounded-xl transition-colors"
            target="_blank"
            rel="noopener"
          >
            <span class="text-2xl">📍</span>
            <div class="text-left">
              <div class="font-bold text-gray-900">2GIS</div>
              <div class="text-sm text-gray-600">4.8 / 5.0</div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <ScrollAnimations />
</Layout>

<script>
  function openBookingModal() {
    console.log('Opening booking modal');
    alert('Модальное окно записи будет здесь');
  }
</script>
