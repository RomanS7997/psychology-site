---
// src/pages/specialists.astro
import Layout from '../layouts/Layout.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SEO from '../components/SEO.astro';
---

<SEO 
  title="Моя команда - Специалисты в Одинцово | Кабинет психолога"
  description="Психолог и педагоги в Одинцово. Квалифицированная помощь взрослым и детям. Познакомьтесь с моей командой."
  keywords="психолог Одинцово, специалисты, команда педагогов"
  schema="person"
/>

<Layout 
  title="Моя команда - Специалисты в Одинцово | Кабинет психолога"
  description="Психолог и педагоги в Одинцово."
>

  <Breadcrumbs 
    items={[
      { label: 'Главная', href: '/' },
      { label: 'Специалисты' }
    ]}
  />

  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden bg-gradient-to-br from-teal-50 via-blue-50 to-purple-50" data-animate="fade">
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-[#4894B2] to-[#18698F] bg-clip-text text-transparent">
          Моя команда профессионалов
        </h1>
        <p class="text-xl text-gray-700 mb-8">
          Познакомьтесь со мной и моей командой педагогов — опытными специалистами, 
          которые помогут вам и вашим детям
        </p>
        
        <!-- Статистика команды -->
        <div class="grid grid-cols-2 gap-8 max-w-md mx-auto" data-stagger>
          <div class="text-center">
            <div class="text-4xl font-bold text-[#4894B2] mb-2">4</div>
            <div class="text-sm text-gray-600">специалиста</div>
          </div>
          <div class="text-center">
            <div class="text-4xl font-bold text-[#4894B2] mb-2" data-counter="15" data-suffix="+">0</div>
            <div class="text-sm text-gray-600">лет опыта</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Сетка специалистов -->
  <section class="py-20 bg-gray-50" data-animate="slide-up">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="space-y-20">
        
        <!-- Специалист 1: Юлия Ляпина -->
        <div id="specialist-1" class="specialist-card bg-white rounded-3xl shadow-2xl overflow-hidden" data-categories="adult family">
          <div class="grid md:grid-cols-5 gap-0">
            
            <!-- Фото -->
            <div class="md:col-span-2 relative flex flex-col">
              <div class="aspect-[3/4] relative overflow-hidden">
                <img src="/psychology-site/images/specialists/julia-lyapina.jpg" alt="Юлия Ляпина" class="w-full h-full object-cover object-top" />

              </div>
              <!-- Бейджи под фото -->
              <div class="flex-1 flex flex-col items-center justify-center gap-3 p-6 bg-gradient-to-b from-white to-[#F2F7FD]">
                <span class="px-5 py-2.5 bg-[#4894B2] text-white text-sm font-bold rounded-full shadow-md">
                  Психолог
                </span>
                <span class="px-5 py-2.5 bg-white text-[#4894B2] text-sm font-bold rounded-full shadow-md border-2 border-[#4894B2]">
                  15+ лет опыта
                </span>
              </div>
            </div>
            
            <!-- Детали -->
            <div class="md:col-span-3 p-10">
              
              <h2 class="text-4xl font-bold text-gray-900 mb-2">Юлия Ляпина</h2>
              <p class="text-xl text-[#4894B2] mb-8">Психолог, специалист по работе с детьми и взрослыми</p>
              
              <!-- Образование -->
              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                  <span class="text-2xl">🎓</span>
                  Образование:
                </h3>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start gap-3">
                    <span class="text-[#4894B2] mt-1">•</span>
                    <span>СГУ им. Н.Г. Чернышевского, факультет психологии</span>
                  </li>
                </ul>
              </div>
              
              <!-- Специализация -->
              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Специализация:</h3>
                <div class="flex flex-wrap gap-2">
                  <span class="px-4 py-2 bg-[#F2F7FD] text-teal-700 rounded-full text-sm font-semibold">Тревожные расстройства</span>
                  <span class="px-4 py-2 bg-[#F2F7FD] text-[#4894B2] rounded-full text-sm font-semibold">Проблемы в отношениях</span>
                  <span class="px-4 py-2 bg-[#F2F7FD] text-[#4894B2] rounded-full text-sm font-semibold">Работа с детьми</span>
                  <span class="px-4 py-2 bg-[#F2F7FD] text-[#4894B2] rounded-full text-sm font-semibold">Семейная терапия</span>
                </div>
              </div>
              
              <!-- Методы работы -->
              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Методы работы:</h3>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Арт-терапия</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Когнитивно-поведенческая терапия (КПТ)</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>МАК (метафорические ассоциативные карты)</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>ДПДГ, расстановки</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Системный подход в семейной терапии</span>
                  </li>
                </ul>
              </div>
              
              <!-- Статистика -->
              <div class="grid grid-cols-2 gap-6 mb-8 bg-[#F2F7FD] rounded-2xl p-6">
                <div class="text-center">
                  <div class="text-3xl font-bold text-[#4894B2] mb-1">15</div>
                  <div class="text-sm text-gray-600">лет практики</div>
                </div>
                <div class="text-center">
                  <div class="text-3xl font-bold text-[#4894B2] mb-1">100%</div>
                  <div class="text-sm text-gray-600">результат</div>
                </div>
              </div>
              
              <!-- О себе -->
              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4">О себе:</h3>
                <p class="text-gray-700 leading-relaxed">
                  Я работаю с клиентами более 15 лет. Специализируюсь на работе с детьми, подростками 
                  и взрослыми. Использую научно-обоснованные методы. Моя задача — не держать клиентов 
                  годами в терапии, а научить самостоятельно справляться с трудностями.
                </p>
              </div>
              
              <!-- CTA -->
              <div class="flex flex-col sm:flex-row gap-4">
                <button 
                  onclick="openBookingModal()"
                  class="flex-1 px-8  bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full font-semibold transition shadow-lg hover:shadow-xl hover:scale-105"
                >
                  Записаться к Юлии Ляпиной
                </button>
                <button 
                  class="px-8 py-4 bg-white hover:bg-gray-50 text-[#4894B2] border-2 border-[#4894B2] rounded-full font-bold transition"
                >
                  Задать вопрос
                </button>
              </div>
              
            </div>
          </div>
        </div>

        <!-- Специалист 2: Власихина Людмила Степановна -->
        <div id="specialist-2" class="specialist-card bg-white rounded-3xl shadow-2xl overflow-hidden" data-categories="children">
          <div class="grid md:grid-cols-5 gap-0">
            
            <div class="md:col-span-2 relative flex flex-col">
              <div class="aspect-[3/4] relative overflow-hidden">
                <img src="/psychology-site/images/specialists/vlasihina-lyudmila.jpg" alt="Власихина Людмила Степановна" class="w-full h-full object-cover object-top" />

              </div>
              <div class="flex-1 flex flex-col items-center justify-center gap-3 p-6 bg-gradient-to-b from-white to-[#F2F7FD]">
                <span class="px-5 py-2.5 bg-[#4894B2] text-white text-sm font-bold rounded-full shadow-md">
                  Монтессори-педагог
                </span>
                <span class="px-5 py-2.5 bg-white text-[#4894B2] text-sm font-bold rounded-full shadow-md border-2 border-[#4894B2]">
                  20+ лет опыта
                </span>
              </div>
            </div>
            
            <div class="md:col-span-3 p-10">
              
              <h2 class="text-4xl font-bold text-gray-900 mb-2">Власихина Людмила Степановна</h2>
              <p class="text-xl text-[#4894B2] mb-8">Монтессори-педагог, 3–6 лет</p>

              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                  <span class="text-2xl">🎓</span>
                  Образование:
                </h3>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start gap-3">
                    <span class="text-[#4894B2] mt-1">•</span>
                    <span>Ассоциация Монтессори-педагогов России</span>
                  </li>
                </ul>
              </div>

              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Специализация:</h3>
                <div class="flex flex-wrap gap-2">
                  <span class="px-4 py-2 bg-[#F2F7FD] text-[#4894B2] rounded-full text-sm font-semibold">Дети 3–6 лет</span>
                  <span class="px-4 py-2 bg-[#F2F7FD] text-[#4894B2] rounded-full text-sm font-semibold">Монтессори-методика</span>
                  <span class="px-4 py-2 bg-[#F2F7FD] text-[#4894B2] rounded-full text-sm font-semibold">Подготовка к школе</span>
                  <span class="px-4 py-2 bg-[#F2F7FD] text-[#4894B2] rounded-full text-sm font-semibold">Дошкольное развитие</span>
                </div>
              </div>

              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Направления работы:</h3>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Математика и обучение чтению</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Сенсорика и развитие логики</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Творческие навыки</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Подготовка к школе</span>
                  </li>
                </ul>
              </div>

              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Методы работы:</h3>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Методика Монтессори</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Кубики Зайцева</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Авторские наработки из личного опыта</span>
                  </li>
                </ul>
              </div>

              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4">О себе:</h3>
                <p class="text-gray-700 leading-relaxed">
                  Работаю с детьми дошкольного возраста. Готовлю детей к школе:
                  математика, чтение, сенсорика, развитие логики и творческие навыки.
                  Применяю методику кубиков Зайцева, Монтессори и личный опыт.
                </p>
              </div>
              
              <div class="flex flex-col sm:flex-row gap-4">
                <button 
                  onclick="openBookingModal()"
                  class="flex-1 px-8 py-4 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full font-semibold transition shadow-lg hover:shadow-xl hover:scale-105"
                >
                  Записать ребёнка
                </button>
              </div>
              
            </div>
          </div>
        </div>

        <!-- Специалист 3: Евграфова Наталья Викторовна -->
        <div id="specialist-3" class="specialist-card bg-white rounded-3xl shadow-2xl overflow-hidden" data-categories="children">
          <div class="grid md:grid-cols-5 gap-0">

            <div class="md:col-span-2 relative flex flex-col">
              <div class="aspect-[3/4] relative overflow-hidden">
                <img src="/psychology-site/images/specialists/evgrafova-natalia.jpg" alt="Евграфова Наталья Викторовна" class="w-full h-full object-cover object-top" />
              </div>
              <div class="flex-1 flex flex-col items-center justify-center gap-3 p-6 bg-gradient-to-b from-white to-[#F2F7FD]">
                <span class="px-5 py-2.5 bg-[#4894B2] text-white text-sm font-bold rounded-full shadow-md">
                  Логопед
                </span>
                <span class="px-5 py-2.5 bg-white text-[#4894B2] text-sm font-bold rounded-full shadow-md border-2 border-[#4894B2]">
                  Учитель русского языка
                </span>
              </div>
            </div>

            <div class="md:col-span-3 p-10">

              <h2 class="text-4xl font-bold text-gray-900 mb-2">Евграфова Наталья Викторовна</h2>
              <p class="text-xl text-[#4894B2] mb-8">Учитель-логопед, учитель русского языка и литературы</p>

              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                  <span class="text-2xl">🎓</span>
                  Образование:
                </h3>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start gap-3">
                    <span class="text-[#4894B2] mt-1">•</span>
                    <span>РГПУ им. А.И. Герцена — высшее, филологический факультет</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-[#4894B2] mt-1">•</span>
                    <span>ФГБНУ «ИСиО РАО» — высшее, логопедический факультет</span>
                  </li>
                </ul>
              </div>

              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                  <span class="text-2xl">📘</span>
                  Дополнительное образование:
                </h3>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start gap-3">
                    <span class="text-[#4894B2] mt-1">•</span>
                    <span>Курсы Пятибратовой Н.В. по инновационным методикам</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-[#4894B2] mt-1">•</span>
                    <span>Курсы Поневежской Т.Ю. — нейропсихологический подход к пониманию и преодолению школьных трудностей</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-[#4894B2] mt-1">•</span>
                    <span>АНО ДПО «Северо-Западная академия профессионального образования и профессионального обучения» — «Нарушение письма у школьников»</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-[#4894B2] mt-1">•</span>
                    <span>Учебный центр «Профи» — «Педагог по скорочтению и развитию памяти у младших школьников»</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-[#4894B2] mt-1">•</span>
                    <span>Курсы Светланы Томилиной «Логопедический массаж»</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-[#4894B2] mt-1">•</span>
                    <span>Курсы Ангелины Сыщенко «Запуск речи и ССС»</span>
                  </li>
                </ul>
              </div>

              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Специализация:</h3>
                <div class="flex flex-wrap gap-2">
                  <span class="px-4 py-2 bg-[#F2F7FD] text-[#4894B2] rounded-full text-sm font-semibold">Дети 4–18 лет</span>
                  <span class="px-4 py-2 bg-[#F2F7FD] text-[#4894B2] rounded-full text-sm font-semibold">Логопедия</span>
                  <span class="px-4 py-2 bg-[#F2F7FD] text-[#4894B2] rounded-full text-sm font-semibold">Русский язык и литература</span>
                  <span class="px-4 py-2 bg-[#F2F7FD] text-[#4894B2] rounded-full text-sm font-semibold">Подготовка к ВПР, ОГЭ, ЕГЭ</span>
                  <span class="px-4 py-2 bg-[#F2F7FD] text-[#4894B2] rounded-full text-sm font-semibold">Скорочтение и развитие памяти</span>
                </div>
              </div>

              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Направления работы логопеда:</h3>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Постановка звуков и коррекция произношения</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Развитие речи и грамматики</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Артикуляционная моторика</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-[#4894B2]">✓</span>
                    <span>Развитие фонематического слуха</span>
                  </li>
                </ul>
              </div>

              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Навыки:</h3>
                <p class="text-gray-700 leading-relaxed">
                  Владение грамотной речью и современными методами подачи знаний,
                  навыки репетиторства, умение организовать учебный процесс,
                  индивидуальный подход к учащимся. Опыт работы с детьми от 4 до 18 лет.
                  Многолетний опыт подготовки учащихся к ВПР, ОГЭ и ЕГЭ.
                </p>
              </div>

              <div class="flex flex-col sm:flex-row gap-4">
                <button
                  onclick="openBookingModal()"
                  class="flex-1 px-8 py-4 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full font-semibold transition shadow-lg hover:shadow-xl hover:scale-105"
                >
                  Записать ребёнка
                </button>
              </div>

            </div>
          </div>
        </div>

        <!-- Специалист 4: Стрижкова Наталья Петровна -->
        <div id="specialist-4" class="specialist-card bg-white rounded-3xl shadow-2xl overflow-hidden" data-categories="children">
          <div class="grid md:grid-cols-5 gap-0">

            <div class="md:col-span-2 relative flex flex-col">
              <div class="aspect-[3/4] relative overflow-hidden">
                <img src="/psychology-site/images/specialists/strizhkova-natalia.jpg" alt="Стрижкова Наталья Петровна" class="w-full h-full object-cover object-top" />
              </div>
              <div class="flex-1 flex flex-col items-center justify-center gap-3 p-6 bg-gradient-to-b from-white to-[#F2F7FD]">
                <span class="px-5 py-2.5 bg-[#4894B2] text-white text-sm font-bold rounded-full shadow-md">
                  Педагог, репетитор
                </span>
                <span class="px-5 py-2.5 bg-white text-[#4894B2] text-sm font-bold rounded-full shadow-md border-2 border-[#4894B2]">
                  26+ лет опыта
                </span>
              </div>
            </div>

            <div class="md:col-span-3 p-10">

              <h2 class="text-4xl font-bold text-gray-900 mb-2">Стрижкова Наталья Петровна</h2>
              <p class="text-xl text-[#4894B2] mb-8">Педагог, репетитор</p>

              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                  <span class="text-2xl">🎓</span>
                  Образование:
                </h3>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start gap-3">
                    <span class="text-[#4894B2] mt-1">•</span>
                    <span>Оренбургский государственный университет — высшее (1999)</span>
                  </li>
                </ul>
              </div>

              <div class="mb-8">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Специализация:</h3>
