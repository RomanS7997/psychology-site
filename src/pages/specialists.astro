  <!-- JS для слайдера дипломов -->
  <script is:inline>
    function initCertificateSliders() {
      document.querySelectorAll('.certificates-slider').forEach(slider => {
        const track = slider.querySelector('.certificates-track');
        const prevBtn = slider.querySelector('.cert-prev');
        const nextBtn = slider.querySelector('.cert-next');
        
        if (!track || !prevBtn || !nextBtn) return;
        
        prevBtn.addEventListener('click', () => {
          track.scrollBy({ left: -320, behavior: 'smooth' });
        });
        
        nextBtn.addEventListener('click', () => {
          track.scrollBy({ left: 320, behavior: 'smooth' });
        });
      });
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCertificateSliders);
    } else {
      initCertificateSliders();
    }
    
    document.addEventListener('astro:page-load', initCertificateSliders);
  </script>

