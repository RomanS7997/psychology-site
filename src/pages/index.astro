---
// ПОЛНАЯ главная страница с ВСЕМИ блоками из плана
import Layout from '../layouts/Layout.astro';
import NewHero from '../components/NewHero.astro';
import SocialProof from '../components/global/SocialProof.astro';
import SEO from '../components/SEO.astro';
import FAQ from '../components/FAQ.astro';
import WaveDivider from '../components/WaveDivider.astro'; 
import ScrollAnimations from '../components/ScrollAnimations.astro';
---

<SEO 
  title="Психолог в Одинцово и Лесном городке | Консультации онлайн и офлайн"
  description="Кабинет психолога Ляпина Юлия в Одинцово. Консультирование взрослых и детей, развивающие программы. Записаться онлайн."
  keywords="психолог Одинцово, психолог Лесной городок, психотерапия, консультации онлайн, детский психолог"
  schema="organization"
/>

<Layout 
  title="Психолог в Одинцово и Лесном городке | Консультации онлайн и офлайн"
  description="Кабинет психолога Ляпина Юлия в Одинцово. Консультирование взрослых и детей, развивающие программы."
>
  <!-- БЛОК 1: Hero Section (уже готов, просто используем) -->
  <NewHero 
    title="Кабинет психолога Ляпина Юлия"
    subtitle="Профессиональная психологическая помощь взрослым и детям. Семейная терапия и консультирование. Развивающие программы для детей 4-9 лет."
  />



  <!-- БЛОК 3: С чем мы поможем (9 карточек проблем) -->
  <section id="services" class="relative py-20 overflow-hidden">
    <!-- Фоновый градиент -->
    <div class="absolute inset-0 bg-gradient-to-br from-[rgba(230,215,205,0.2)] via-[rgba(215,198,188,0.26)] to-[rgba(200,180,170,0.35)]"></div>
    
    <!-- Декоративные элементы -->
    <div class="absolute top-20 right-10 w-32 h-32 bg-[#4894B2]/15 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 left-10 w-40 h-40 bg-[#d9797d]/15 rounded-full blur-3xl"></div>
    
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
      <div data-animate="fade">
        <h2 class="text-4xl md:text-5xl font-bold text-center text-gray-900 mb-4">
          С какими запросами к нам обращаются
        </h2>
        <p class="text-center text-gray-600 text-lg mb-16 max-w-2xl mx-auto">
          Найдите себя в одной из ситуаций. Нажмите на карточку, чтобы узнать подробности.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-stagger>
        
        <!-- Карточка 1: Тревога -->
        <div class="accordion-card bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100 group cursor-pointer flex flex-col">
          <div class="flex items-start justify-between mb-4">
            <div class="w-16 h-16 text-[#4894B2] transition-transform duration-300 group-hover:scale-110 flex-shrink-0">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="32" cy="32" r="28" stroke="currentColor" stroke-width="2" fill="none" opacity="0.2"/>
                <path d="M32 16v8m0 16v8m-12-20l5.656 5.656m12.688 0L44 34M16 32h8m16 0h8m-36 0c0 8.837 7.163 16 16 16s16-7.163 16-16-7.163-16-16-16-16 7.163-16 16z" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
              </svg>
            </div>
            <svg class="w-6 h-6 text-[#4894B2] transition-transform duration-300 accordion-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Тревожное расстройство</h3>

          <!-- Раскрывающийся контент -->
          <div class="accordion-content flex-grow" style="max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out;">
            <div class="pt-4 border-t border-gray-200 mt-4">
              <h4 class="font-semibold text-gray-900 mb-3">С чем работаю:</h4>
              <ul class="space-y-2 mb-4 text-sm text-gray-600">
                <li class="flex items-start gap-2">
                  <span class="text-[#4894B2] mt-1">✓</span>
                  <span>Панические атаки</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4894B2] mt-1">✓</span>
                  <span>Тревога</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4894B2] mt-1">✓</span>
                  <span>Навязчивые мысли и постоянное беспокойство</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4894B2] mt-1">✓</span>
                  <span>Специфические фобии</span>
                </li>
              </ul>
              <p class="text-sm text-gray-600 mb-4">
                Использую когнитивно-поведенческую терапию (КПТ), дыхательные техники и ДПДГ — эффективные методы работы с тревожными расстройствами. Результат заметен уже через 4-6 сессий.
              </p>
              <button 
                onclick="openBookingModal(); event.stopPropagation();"
                class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white font-semibold rounded-full transition-all duration-300"
              >
                Записаться на консультацию
              </button>
            </div>
          </div>
        </div>

        <!-- Карточка 2: Отношения -->
        <div class="accordion-card bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100 group cursor-pointer flex flex-col">
          <div class="flex items-start justify-between mb-4">
            <div class="w-16 h-16 text-[#d9797d] transition-transform duration-300 group-hover:scale-110 flex-shrink-0">
             <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24">
	<g fill="none">
		<path fill="#ffbfc5" d="m8.658 12.026l3.35-6.62l-1.531-1.396a5.59 5.59 0 0 0-8.891 1.423a5.425 5.425 0 0 0 1.04 6.325l9.089 9.842l3.17-9.574z" />
		<path fill="#ff808c" d="M22.438 5.433a5.59 5.59 0 0 0-8.891-1.423l-1.532 1.396l-3.35 6.62h6.222l-3.17 9.574l9.381-9.663a5.39 5.39 0 0 0 1.34-6.504" />
		<path stroke="#191919" stroke-linecap="round" stroke-linejoin="round" d="m11.715 21.6l-9.09-9.842a5.43 5.43 0 0 1-1.039-6.325a5.59 5.59 0 0 1 8.891-1.423l1.532 1.396L13.54 4.01a5.59 5.59 0 0 1 8.896 1.423a5.39 5.39 0 0 1-1.34 6.504z" stroke-width="1" />
		<path stroke="#191919" stroke-linecap="round" stroke-linejoin="round" d="m12.009 5.406l-3.35 6.62h6.222l-3.17 9.574" stroke-width="1" />
	</g>
</svg>
            </div>
            <svg class="w-6 h-6 text-[#d9797d] transition-transform duration-300 accordion-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Проблемы в отношениях</h3>

          <div class="accordion-content flex-grow" style="max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out;">
            <div class="pt-4 border-t border-gray-200 mt-4">
              <h4 class="font-semibold text-gray-900 mb-3">Работаю с:</h4>
              <ul class="space-y-2 mb-4 text-sm text-gray-600">
                <li class="flex items-start gap-2">
                  <span class="text-[#d9797d] mt-1">✓</span>
                  <span>Конфликты и непонимание в паре</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#d9797d] mt-1">✓</span>
                  <span>Ревность, недоверие, контроль</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#d9797d] mt-1">✓</span>
                  <span>Измена и восстановление доверия</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#d9797d] mt-1">✓</span>
                  <span>Подготовка к разводу или его переживание</span>
                </li>
              </ul>
              <p class="text-sm text-gray-600 mb-4">
                Семейная терапия помогает наладить коммуникацию, восстановить близость или принять решение о расставании экологично для обеих сторон.
              </p>
              <button
                onclick="openBookingModal(); event.stopPropagation();"
                class="w-full px-6 py-3 bg-[#d9797d] hover:bg-[#c88981] text-white font-semibold rounded-full transition-all duration-300"
              >
                Записаться на консультацию
              </button>
            </div>
          </div>
        </div>

        <!-- Карточка 3: Дети -->
        <div class="accordion-card bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100 group cursor-pointer flex flex-col">
          <div class="flex items-start justify-between mb-4">
            <div class="w-16 h-16 text-[#4894B2] transition-transform duration-300 group-hover:scale-110 flex-shrink-0">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="32" cy="24" r="12" stroke="currentColor" stroke-width="2.5"/>
                <path d="M16 52c0-8.837 7.163-16 16-16s16 7.163 16 16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <circle cx="26" cy="22" r="2" fill="currentColor"/>
                <circle cx="38" cy="22" r="2" fill="currentColor"/>
                <path d="M26 28c2 2 4 2 6 2s4 0 6-2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <svg class="w-6 h-6 text-[#4894B2] transition-transform duration-300 accordion-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Поведение ребенка</h3>

          <div class="accordion-content flex-grow" style="max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out;">
            <div class="pt-4 border-t border-gray-200 mt-4">
              <h4 class="font-semibold text-gray-900 mb-3">Помогаю с:</h4>
              <ul class="space-y-2 mb-4 text-sm text-gray-600">
                <li class="flex items-start gap-2">
                  <span class="text-[#4894B2] mt-1">✓</span>
                  <span>Истерики, непослушание, протесты</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4894B2] mt-1">✓</span>
                  <span>Агрессия, драки, конфликты</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4894B2] mt-1">✓</span>
                  <span>Проблемы с учебой, мотивацией</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4894B2] mt-1">✓</span>
                  <span>Адаптация к садику/школе</span>
                </li>
              </ul>
              <p class="text-sm text-gray-600 mb-4">
                Работаю с ребенком через игру и арт-терапию. Обязательно консультирую родителей по выстраиванию эффективных границ и воспитанию.
              </p>
              <button
                onclick="openBookingModal(); event.stopPropagation();"
                class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white font-semibold rounded-full transition-all duration-300"
              >
                Записаться на консультацию
              </button>
            </div>
          </div>
        </div>

        <!-- Карточка 4: Самооценка -->
        <div class="accordion-card bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100 group cursor-pointer flex flex-col">
          <div class="flex items-start justify-between mb-4">
            <div class="w-16 h-16 text-[#18698F] transition-transform duration-300 group-hover:scale-110 flex-shrink-0">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="32" cy="28" r="10" stroke="currentColor" stroke-width="2.5"/>
                <path d="M20 52c0-6.627 5.373-12 12-12s12 5.373 12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <path d="M28 26l-2 2m10-2l2 2m-10 4h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M18 18L14 22m32-4l4 4M32 8v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <svg class="w-6 h-6 text-[#18698F] transition-transform duration-300 accordion-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Низкая самооценка</h3>

          <div class="accordion-content flex-grow" style="max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out;">
            <div class="pt-4 border-t border-gray-200 mt-4">
              <h4 class="font-semibold text-gray-900 mb-3">Помогаю с:</h4>
              <ul class="space-y-2 mb-4 text-sm text-gray-600">
                <li class="flex items-start gap-2">
                  <span class="text-[#18698F] mt-1">✓</span>
                  <span>Неуверенность в себе</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#18698F] mt-1">✓</span>
                  <span>Негативные мысли о себе</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#18698F] mt-1">✓</span>
                  <span>Страх оценки и критики</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#18698F] mt-1">✓</span>
                  <span>Постоянное сравнение с другими</span>
                </li>
              </ul>
              <p class="text-sm text-gray-600 mb-4">
                Работаем над формированием здоровой самооценки через выявление и изменение деструктивных убеждений. Учу самосостраданию и принятию себя.
              </p>
              <button
                onclick="openBookingModal(); event.stopPropagation();"
                class="w-full px-6 py-3 bg-[#18698F] hover:bg-[#0f5270] text-white font-semibold rounded-full transition-all duration-300"
              >
                Записаться на консультацию
              </button>
            </div>
          </div>
        </div>

        <!-- Карточка 5: Кризисы -->
        <div class="accordion-card bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100 group cursor-pointer flex flex-col">
          <div class="flex items-start justify-between mb-4">
            <div class="w-16 h-16 text-[#4894B2] transition-transform duration-300 group-hover:scale-110 flex-shrink-0">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M32 8C18.745 8 8 18.745 8 32s10.745 24 24 24 24-10.745 24-24S45.255 8 32 8z" stroke="currentColor" stroke-width="2.5"/>
                <path d="M32 16v16l8 8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <circle cx="32" cy="32" r="2" fill="currentColor"/>
              </svg>
            </div>
            <svg class="w-6 h-6 text-[#4894B2] transition-transform duration-300 accordion-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Возрастной кризис</h3>

          <div class="accordion-content flex-grow" style="max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out;">
            <div class="pt-4 border-t border-gray-200 mt-4">
              <h4 class="font-semibold text-gray-900 mb-3">Работаю с:</h4>
              <ul class="space-y-2 mb-4 text-sm text-gray-600">
                <li class="flex items-start gap-2">
                  <span class="text-[#4894B2] mt-1">✓</span>
                  <span>Ощущение пустоты</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4894B2] mt-1">✓</span>
                  <span>Потеря смысла и цели в жизни</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[#4894B2] mt-1">✓</span>
                  <span>Профессиональное выгорание</span>
                </li>
              </ul>
              <p class="text-sm text-gray-600 mb-4">
                Помогаю найти новые смыслы, переосмыслить жизненный путь и наметить направление развития. Кризис — это возможность для роста.
              </p>
              <button
                onclick="openBookingModal(); event.stopPropagation();"
                class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white font-semibold rounded-full transition-all duration-300"
              >
                Записаться на консультацию
              </button>
            </div>
          </div>
        </div>

        <!-- Карточка 6: Подготовка к школе -->
        <div class="accordion-card bg-gradient-to-br from-[#F2F7FD] to-white backdrop-blur-sm rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-[#4894B2]/30 relative overflow-hidden group cursor-pointer">
          <div class="flex items-start justify-between mb-4">
            <div class="w-16 h-16 text-[#4894B2] transition-transform duration-300 group-hover:scale-110 flex-shrink-0">
             <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 128 128">
	<path fill="#c62828" d="m31.37 26.45l.17-18.43L40 5.43l9.75 16.73z" />
	<path fill="#37474f" d="M36.76 20.48s-2.6-11.89.34-13.07c5.23-2.09 9.31 11.65 9.31 11.65z" opacity="0.59" />
	<path fill="#f44336" d="M20.59 32.81c-.09-1.63-2.29-14.63 1.05-21.88c1.53-3.31 7.81-5.51 13.43-6.76c1.39-.31 4.98-.51 7.21 2.05c2.01 2.31 4.98 7.37 7.91 15l-2.11 4.54s-2.91-7.7-5.82-14.06c-2.41-5.27-5.47-3.52-5.78-2.29c-.56 2.26 2.3 14.51 2.3 14.51c-4.16 1.77-18.19 8.89-18.19 8.89" />
	<path fill="#455a64" d="m42.36 17.37l1.75-8.5L51 4.88l8.29.02l6.9 5.59l1.91 10.9l-8.33-2.81l-1.13-7.81l-7.64-.19l-1.02 6.21z" />
	<path fill="#ff7555" d="M35.06 4.18c-5.62 1.24-11.27 3.03-13.43 6.76c-1.24 2.14-1.96 7.75-1.82 12.96c1.09-1.72 5.54-4.69 8.86-6.13c3.31-1.44 3.69-2.87 3.74-3.5c.25-2.86.01-5.22.85-7.24c1.06-2.56 2.57-2.88 3.45-3.01c-.67 0-1.26.07-1.65.16m4.53.28c-.54-.19-1.08-.31-1.6-.37c.54.14 1.07.32 1.6.37" />
	<path fill="none" stroke="#784d30" stroke-miterlimit="10" stroke-width="9.816" d="M89.99 109.24c14.88-3.95 19.32-20.76 23.54-22.17" />
	<path fill="#c62828" d="M104.48 74.9c1.09 7.09 3.23 7.62 6.96 7.43c5.65-.28 6.27-1.58 7.53-11.26c1.56-12.02-2.95-28.77-6.84-40.25c-2.06-6.08-1.85-10.25-6.44-14.89c-2.52-2.55-12.33-6.3-15.18-1.42c-1.96 3.36-.98 6.77.89 9.47c5.43 7.86 10.43 33.77 13.08 50.92" />
	<path fill="#37474f" d="M93.06 26.91c1.04 2.13 2.11 4.89 2.98 8c8.86-.27 18.46 3.98 18.46 3.72c0-.22-.75-5.99-3.19-11.71c-1.06-2.48-4.29-9.28-8.29-8.62c-5.03.84-9.96 8.61-9.96 8.61" opacity="0.59" />
