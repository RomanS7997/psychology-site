---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SEO from '../components/SEO.astro';
---

<SEO 
  title="Контакты - Кабинет психолога в Одинцово | Записаться на прием"
  description="Контакты психологического центра в Одинцово. Адрес, телефон, email, карта проезда. Записаться на консультацию онлайн или по телефону."
  keywords="контакты психолога Одинцово, адрес центра, записаться к психологу"
  schema="localbusiness"
/>

<Layout 
  title="Контакты - Кабинет психолога в Одинцово | Записаться на прием"
  description="Контакты психологического центра в Одинцово."
>

  <Breadcrumbs 
    items={[
      { label: 'Главная', href: '/' },
      { label: 'Контакты' }
    ]}
  />

  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden bg-gradient-to-br from-[#F2F7FD] via-white to-[#F2F7FD]" data-animate="fade">
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-[#4894B2] to-[#18698F] bg-clip-text text-transparent">
          Свяжитесь с нами
        </h1>
        <p class="text-xl text-gray-700 mb-8">
          Ответим на все ваши вопросы и поможем записаться на консультацию
        </p>
      </div>
    </div>
  </section>

  <!-- Основной контент: Форма + Контакты -->
  <section class="py-20 bg-white" data-animate="slide-up">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 max-w-6xl mx-auto">
        
        <!-- Форма обратной связи -->
        <div class="bg-gray-50 rounded-3xl p-8 shadow-lg">
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Напишите нам</h2>
          
          <form class="space-y-4" onsubmit="handleFormSubmit(event)">
            
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Ваше имя *</label>
              <input 
                type="text" 
                name="name"
                required
                class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-[#4894B2] focus:outline-none transition"
                placeholder="Введите ваше имя"
              >
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Телефон *</label>
              <input 
                type="tel" 
                name="phone"
                required
                class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-[#4894B2] focus:outline-none transition"
                placeholder="+7 (___) ___-__-__"
              >
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Email</label>
              <input 
                type="email" 
                name="email"
                class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-[#4894B2] focus:outline-none transition"
                placeholder="your@email.com"
              >
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Тема обращения</label>
              <select 
                name="subject"
                class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-[#4894B2] focus:outline-none transition"
              >
                <option>Выберите тему</option>
                <option>Запись на консультацию</option>
                <option>Вопрос о программах</option>
                <option>Вопрос о стоимости</option>
                <option>Сотрудничество</option>
                <option>Другое</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Ваше сообщение *</label>
              <textarea 
                name="message"
                required
                rows="5"
                class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-[#4894B2] focus:outline-none transition resize-none"
                placeholder="Расскажите о вашем запросе..."
              ></textarea>
            </div>

            <button 
              type="submit"
              class="w-full px-8 py-4 bg-gradient-to-r from-teal-600 to-blue-600 hover:from-teal-700 hover:to-blue-700 text-white rounded-full font-bold transition shadow-lg hover:shadow-xl"
            >
              Отправить сообщение
            </button>

          </form>
          
          <p class="text-sm text-gray-600 mt-4 text-center">
            ⏱️ Мы ответим в течение 15 минут в рабочее время
          </p>
        </div>
        
        <!-- Контактная информация -->
        <div class="space-y-8">
          
          <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-8">Контактная информация</h2>
          </div>

          <!-- Телефон -->
          <div class="flex gap-4 items-start">
            <div class="flex-shrink-0 w-14 h-14 rounded-full bg-teal-100 text-[#4894B2] flex items-center justify-center text-2xl">
              📞
            </div>
            <div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">Телефон</h3>
              <a href="tel:+79151955132" class="text-2xl font-bold text-[#4894B2] hover:text-teal-700 transition">
                +7 (915) 195-51-32
              </a>
              <p class="text-sm text-gray-600 mt-1">Ежедневно с 9:00 до 21:00</p>
            </div>
          </div>
          
          <!-- Email -->
          <div class="flex gap-4 items-start">
            <div class="flex-shrink-0 w-14 h-14 rounded-full bg-[#F2F7FD] text-[#4894B2] flex items-center justify-center text-2xl">
              ✉️
            </div>
            <div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">Email</h3>
              <a href="mailto:lyapina_sorokina@mail.ru" class="text-xl text-[#4894B2] hover:text-[#4894B2] transition">
                lyapina_sorokina@mail.ru
              </a>
            </div>
          </div>
          
          <!-- Адрес -->
          <div class="flex gap-4 items-start">
            <div class="flex-shrink-0 w-14 h-14 rounded-full bg-[#F2F7FD] text-[#4894B2] flex items-center justify-center text-2xl">
              📍
            </div>
            <div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">Адрес</h3>
              <p class="text-lg text-gray-700 mb-1">
                г. Москва, ул. Примерная, д. 10, офис 205
              </p>
              <p class="text-sm text-gray-600 mb-2">
                м. Маяковская, 5 минут пешком
              </p>
              <a href="#map" class="text-[#4894B2] hover:text-teal-700 font-semibold inline-flex items-center gap-2 transition">
                Как добраться →
              </a>
            </div>
          </div>
          
          <!-- Мессенджеры -->
          <div class="flex gap-4 items-start">
            <div class="flex-shrink-0 w-14 h-14 rounded-full bg-[#F2F7FD] text-[#4894B2] flex items-center justify-center text-2xl">
              💬
            </div>
            <div>
              <h3 class="text-lg font-bold text-gray-900 mb-3">Мессенджеры</h3>
              <div class="flex gap-3">
                <a 
                  href="https://wa.me/79151955132" 
                  target="_blank"
                  class="px-4 py-2 bg-[#25D366] hover:bg-[#20BA5A] text-white rounded-full font-semibold transition shadow-md hover:shadow-lg flex items-center gap-2"
                >
                  <span>📱</span>
                  WhatsApp
                </a>
                <a 
                  href="https://t.me/psychocenter" 
                  target="_blank"
                  class="px-4 py-2 bg-[#229ED9] hover:bg-[#1E88C5] text-white rounded-full font-semibold transition shadow-md hover:shadow-lg flex items-center gap-2"
                >
                  <span>✈️</span>
                  Telegram
                </a>
              </div>
            </div>
          </div>
          
          <!-- Социальные сети -->
          <div class="pt-6 border-t border-gray-200">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Мы в соцсетях:</h3>
            <div class="flex gap-3">
              <a 
                href="#" 
                class="w-12 h-12 rounded-full bg-[#4894B2] hover:bg-[#18698F] text-white flex items-center justify-center text-xl transition shadow-md hover:shadow-lg"
                title="ВКонтакте"
              >
                VK
              </a>
              <a 
                href="#" 
                class="w-12 h-12 rounded-full bg-gradient-to-br from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white flex items-center justify-center text-xl transition shadow-md hover:shadow-lg"
                title="Instagram"
              >
                IG
              </a>
              <a 
                href="#" 
                class="w-12 h-12 rounded-full bg-[#4894B2] hover:bg-[#4894B2] text-white flex items-center justify-center text-xl transition shadow-md hover:shadow-lg"
                title="YouTube"
              >
                YT
              </a>
            </div>
          </div>

        </div>
        
      </div>
    </div>
  </section>

  <!-- Карта -->
  <section id="map" class="py-20 bg-gray-50" data-animate="fade">
    <div class="container mx-auto px-4 lg:px-8">
      
      <h2 class="text-4xl font-bold text-gray-900 mb-8 text-center">Как нас найти</h2>
      
      <!-- Яндекс.Карты -->
      <div class="max-w-6xl mx-auto mb-12">
        <div class="rounded-3xl overflow-hidden shadow-2xl">
          <div id="yandex-map" style="width: 100%; height: 500px;"></div>
        </div>
      </div>
      
      <!-- Инструкции как добраться -->
      <div class="max-w-6xl mx-auto">
        <h3 class="text-2xl font-bold text-gray-900 mb-8 text-center">Как добраться:</h3>
        
        <div class="grid md:grid-cols-3 gap-6">
          
          <!-- На метро -->
          <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition">
            <div class="w-16 h-16 rounded-full bg-[#4894B2] text-[#4894B2] flex items-center justify-center text-3xl mx-auto mb-4">
              🚇
            </div>
            <h4 class="text-xl font-bold text-gray-900 mb-3 text-center">На метро</h4>
            <p class="text-gray-700 text-center">
              Станция «Маяковская», выход к ул. Тверская. 
              Пешком 5 минут по ул. Примерная до дома 10.
            </p>
          </div>
          
          <!-- На машине -->
          <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition">
            <div class="w-16 h-16 rounded-full bg-[#F2F7FD] text-[#4894B2] flex items-center justify-center text-3xl mx-auto mb-4">
              🚗
            </div>
            <h4 class="text-xl font-bold text-gray-900 mb-3 text-center">На машине</h4>
            <p class="text-gray-700 text-center">
              Платная парковка рядом с домом. 
              Стоимость: 200₽/час. Есть бесплатные места на соседних улицах.
            </p>
          </div>
          
          <!-- На автобусе -->
          <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition">
            <div class="w-16 h-16 rounded-full bg-[#F2F7FD] text-[#4894B2] flex items-center justify-center text-3xl mx-auto mb-4">
              🚌
            </div>
            <h4 class="text-xl font-bold text-gray-900 mb-3 text-center">На автобусе</h4>
            <p class="text-gray-700 text-center">
              Автобусы №10, №15, №20. 
              Остановка «Ул. Примерная», 2 минуты пешком до центра.
            </p>
          </div>
          
        </div>
      </div>
      
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-to-br from-[#4894B2] to-[#18698F] text-white relative overflow-hidden" data-animate="slide-up">
    <div class="absolute top-0 right-0 w-96 h-96 bg-white rounded-full opacity-10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#F2F7FD] rounded-full opacity-10 blur-3xl"></div>
    
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-bold mb-6">
          Готовы записаться на консультацию?
        </h2>
        <p class="text-xl mb-8 opacity-90">
          Позвоните нам или заполните форму — мы свяжемся с вами в ближайшее время
        </p>
        
        <div class="flex flex-wrap gap-4 justify-center">
          <a 
            href="tel:+79151955132"
            class="px-12 py-5 bg-white hover:bg-gray-100 text-[#4894B2] rounded-full font-bold transition shadow-xl hover:shadow-2xl text-lg"
          >
            Позвонить сейчас
          </a>
          <button 
            onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
            class="px-12 py-5 bg-transparent hover:bg-white/10 text-white border-2 border-white rounded-full font-bold transition text-lg"
          >
            Заполнить форму
          </button>
        </div>
      </div>
    </div>
  </section>

  <ScrollAnimations />
</Layout>

<!-- Яндекс.Карты API -->
<script src="https://api-maps.yandex.ru/2.1/?apikey=YOUR_API_KEY&lang=ru_RU" type="text/javascript"></script>

<script>
  // Обработка формы
  function handleFormSubmit(event) {
    event.preventDefault();
    alert('Спасибо за обращение! Мы свяжемся с вами в ближайшее время.');
    event.target.reset();
  }

  // Инициализация Яндекс.Карты
  function initYandexMap() {
    if (typeof ymaps === 'undefined') {
      console.error('Yandex Maps API не загружен');
      return;
    }

    ymaps.ready(function () {
      // Координаты центра (пример: Маяковская, Москва)
      const map = new ymaps.Map('yandex-map', {
        center: [55.769444, 37.595556], // Координаты м. Маяковская
        zoom: 16,
        controls: ['zoomControl', 'fullscreenControl', 'geolocationControl']
      });

      // Добавление метки
      const placemark = new ymaps.Placemark([55.769444, 37.595556], {
        balloonContent: '<strong>Кабинет психолога Ляпина Юлия</strong><br>ул. Примерная, д. 10, офис 205<br>+7 (915) 195-51-32',
        hintContent: 'Кабинет психолога'
      }, {
        preset: 'islands#blueMedicalIcon',
        iconColor: '#0d9488' // teal-600
      });

      map.geoObjects.add(placemark);

      // Отключение скроллинга карты колесиком мыши
      map.behaviors.disable('scrollZoom');
    });
  }

  // Запуск инициализации карты после загрузки страницы
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initYandexMap);
  } else {
    initYandexMap();
  }
</script>
