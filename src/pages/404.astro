---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Страница не найдена | Кабинет психолога Ляпина Юлия"
  description="Запрашиваемая страница не найдена"
>
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-50 to-gray-100 px-4">
    <div class="max-w-2xl w-full text-center">
      
      <!-- Большая 404 -->
      <div class="mb-8">
        <h1 class="text-9xl md:text-[200px] font-bold text-[#4894B2] opacity-20 leading-none">
          404
        </h1>
      </div>

      <!-- Текст ошибки -->
      <div class="mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Страница не найдена
        </h2>
        <p class="text-lg text-gray-600 mb-2">
          К сожалению, запрашиваемая страница не существует или была удалена
        </p>
        <p class="text-gray-500">
          Возможно, вы перешли по устаревшей ссылке или ошиблись в адресе
        </p>
      </div>

      <!-- Кнопки навигации -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a 
          href="/psychology-site/"
          class="px-8 py-4 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full font-semibold transition-colors shadow-lg hover:shadow-xl"
        >
          На главную
        </a>
        <a 
          href="/psychology-site/contact"
          class="px-8 py-4 bg-white hover:bg-gray-50 text-[#4894B2] border-2 border-[#4894B2] rounded-full font-semibold transition-colors"
        >
          Связаться с нами
        </a>
      </div>

      <!-- Популярные страницы -->
      <div class="bg-white rounded-2xl shadow-lg p-8 max-w-xl mx-auto">
        <h3 class="text-xl font-bold text-gray-900 mb-6">
          Возможно, вас заинтересует:
        </h3>
        
        <div class="grid gap-4 text-left">
          <a 
            href="/psychology-site/services/adult" 
            class="p-4 rounded-xl hover:bg-primary-light transition-colors group"
          >
            <div class="font-semibold text-gray-900 group-hover:text-[#4894B2] transition-colors">
              Консультирование взрослых
            </div>
            <div class="text-sm text-gray-600">Помощь психолога при тревоге, отношениях, развитии детей</div>
          </a>

          <a 
            href="/psychology-site/services/children" 
            class="p-4 rounded-xl hover:bg-primary-light transition-colors group"
          >
            <div class="font-semibold text-gray-900 group-hover:text-[#4894B2] transition-colors">
              Консультирование детей
            </div>
            <div class="text-sm text-gray-600">Детский психолог для детей и подростков</div>
          </a>

          <a 
            href="/psychology-site/programs/umniky" 
            class="p-4 rounded-xl hover:bg-primary-light transition-colors group"
          >
            <div class="font-semibold text-gray-900 group-hover:text-[#4894B2] transition-colors">
              Умники и умницы
            </div>
            <div class="text-sm text-gray-600">Программа подготовки к школе для детей 4-7 лет</div>
          </a>

          <a 
            href="/psychology-site/programs/azbuka" 
            class="p-4 rounded-xl hover:bg-primary-light transition-colors group"
          >
            <div class="font-semibold text-gray-900 group-hover:text-[#4894B2] transition-colors">
              Азбука общения
            </div>
            <div class="text-sm text-gray-600">Развитие эмоционального интеллекта для детей 5-9 лет</div>
          </a>

          <a 
            href="/psychology-site/blog" 
            class="p-4 rounded-xl hover:bg-primary-light transition-colors group"
          >
            <div class="font-semibold text-gray-900 group-hover:text-[#4894B2] transition-colors">
              Блог
            </div>
            <div class="text-sm text-gray-600">Полезные статьи о психологии</div>
          </a>
        </div>
      </div>

      <!-- Контакты -->
      <div class="mt-12 text-gray-600">
        <p class="mb-2">Нужна помощь? Свяжитесь с нами:</p>
        <div class="flex items-center justify-center gap-4 flex-wrap">
          <a href="tel:+79151955132" class="text-[#4894B2] hover:text-[#18698F] font-semibold">
            +7 (915) 195-51-32
          </a>
          <span class="text-gray-400">|</span>
          <a href="mailto:lyapina_sorokina@mail.ru" class="text-[#4894B2] hover:text-[#18698F]">
            lyapina_sorokina@mail.ru
          </a>
        </div>
      </div>

    </div>
  </div>
</Layout>

<style>
  /* Анимация появления */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  div {
    animation: fadeIn 0.6s ease-out;
  }
</style>
