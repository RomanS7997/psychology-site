---
// src/pages/services/adult.astro
import Layout from '../../layouts/Layout.astro';
import ScrollAnimations from '../../components/ScrollAnimations.astro';
import FAQ from '../../components/FAQ.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SEO from '../../components/SEO.astro';
---

<SEO 
  title="Психолог для взрослых в Одинцово и Лесном городке | Консультации онлайн"
  description="Помощь психолога взрослым в Одинцово. Работа с тревогой, прокрастинацией, кризисами, отношениями. Консультации онлайн и офлайн. Запись по телефону."
  keywords="психолог для взрослых Одинцово, психотерапия, консультация психолога онлайн, работа с тревогой"
  schema="service"
/>

<Layout 
  title="Психолог для взрослых в Одинцово и Лесном городке | Консультации онлайн"
  description="Помощь психолога взрослым в Одинцово. Работа с тревогой, прокрастинацией, кризисами, отношениями."
>

  

  <!-- Hero секция -->
  <section class="relative pt-32 pb-20 overflow-hidden" data-animate="fade">
    <!-- Фоновый градиент -->
    <div class="absolute inset-0 bg-gradient-to-br from-[#F2F7FD] via-blue-50 to-purple-50 opacity-50"></div>
    
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        
        <!-- Текст -->
        <div>
          <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-[#4894B2] to-[#18698F] bg-clip-text text-transparent">
            Психологическое консультирование для взрослых
          </h1>
          
          <p class="text-xl text-gray-700 mb-6 leading-relaxed">
            Помогаем разобраться в себе, преодолеть трудности и найти внутренние ресурсы 
            для счастливой жизни
          </p>
          
          <div class="flex flex-wrap gap-4">
            <button 
              onclick="openBookingModal()"
              class="px-8 py-4 bg-[#4894B2] hover:bg-[#18698F]  hover:from-teal-700 hover:to-blue-700 text-white rounded-full font-semibold transition shadow-lg hover:shadow-xl hover:scale-105"
            >
              Записаться на консультацию
            </button>
            <button 
              onclick="openBookingModal('specialist')"
              class="px-8 py-4 bg-white hover:bg-gray-50 text-[#4894B2] border-2 border-teal-600 rounded-full font-semibold transition"
            >
              Первичная консультация
            </button>
          </div>
          
          <!-- Быстрые факты -->
          <div class="grid grid-cols-3 gap-6 mt-12" data-stagger>
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4894B2] mb-2">50 мин</div>
              <div class="text-sm text-gray-600">длительность<br/>сессии</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4894B2] mb-2">5 900₽</div>
              <div class="text-sm text-gray-600">стоимость<br/>консультации</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4894B2] mb-2" data-counter="87" data-suffix="%">0</div>
              <div class="text-sm text-gray-600">отмечают<br/>улучшение</div>
            </div>
          </div>
        </div>
        
        <!-- Изображение -->
        <div class="flex justify-center lg:justify-end " >
        <div class="relative w-full max-w-md">
          <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-2xl">
            <img 
              src="/psychology-site/images/services/adult-consulting.jpg" 
              alt="Консультация психолога" 
              class="w-full h-auto"
            />
            
          </div>
          </div>
          <!-- Декоративные элементы -->
          <div class="absolute -top-6 -right-6 w-24 h-24 bg-teal-400 rounded-full opacity-20 blur-2xl"></div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-[#F2F7FD] rounded-full opacity-20 blur-2xl"></div>
        </div>
        
      </div>
    </div>
  </section>
<Breadcrumbs 
    items={[
      { label: 'Главная', href: '/' },
      { label: 'Услуги', href: '/#services' },
      { label: 'Консультирование взрослых' }
    ]}
  />
  <!-- С чем я работаю -->
  <section id="what-we-help" class="py-20 bg-white" data-animate="slide-up">
    <div class="container mx-auto px-4 lg:px-8">
      <h2 class="text-4xl md:text-5xl font-bold text-center mb-4">
        С чем я помогаю взрослым
      </h2>
      <p class="text-center text-gray-600 text-lg mb-16 max-w-2xl mx-auto">
        Найдите себя в одной из ситуаций и узнайте, как я могу помочь
      </p>
      
      <!-- Сетка проблем -->
      <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto">
        
        <!-- Тревожность и страхи -->
        <div id="anxiety" class="accordion-card bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 cursor-pointer">
          <div class="text-5xl mb-4">😰</div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Тревога, страхи, панические атаки</h3>
          
          <p class="text-gray-700 mb-6 leading-relaxed">
            Если вас преследуют навязчивые мысли, постоянное беспокойство, 
            панические атаки или необъяснимые страхи — помогу.
          </p>
          
          <div class="mb-6">
            <h4 class="font-bold text-gray-900 mb-3">Симптомы:</h4>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Учащенное сердцебиение</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Нехватка воздуха</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Постоянное напряжение</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Страх потери контроля</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Избегание ситуаций</span>
              </li>
            </ul>
          </div>
          
          <div class="bg-[#F2F7FD]/50 p-6 rounded-xl mb-6">
            <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
              <span class="text-[#4894B2]">✓</span>
              Как я помогаю:
            </h4>
            <p class="text-gray-700 mb-4 leading-relaxed">
              Используем когнитивно-поведенческую терапию (КПТ) — самый эффективный 
              метод работы с тревожными расстройствами. Вы научитесь управлять тревогой, 
              а не избегать ее.
            </p>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Техники дыхания и релаксации</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Работа с негативными мыслями</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Постепенная экспозиция страхам</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Профилактика рецидивов</span>
              </li>
            </ul>
          </div>
          
          <button 
            onclick="openBookingModal('anxiety')"
            class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full font-semibold transition"
          >
            Записаться к специалисту по тревоге
          </button>
        </div>
        
        <!-- Прокрастинация -->
        <div id="procrastination" class="accordion-card bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 cursor-pointer">
          <div class="text-5xl mb-4">⏰</div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Прокрастинация, откладывание дел</h3>
          
          <p class="text-gray-700 mb-6 leading-relaxed">
            Если вы постоянно откладываете важные дела, не можете начать 
            и чувствуете вину за невыполненные задачи — я помогу разобраться.
          </p>
          
          <div class="mb-6">
            <h4 class="font-bold text-gray-900 mb-3">Симптомы:</h4>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Постоянное откладывание важных дел</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Сложность с началом задач</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Чувство вины и самокритика</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Страх неудачи или критики</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Перфекционизм</span>
              </li>
            </ul>
          </div>
          
          <div class="bg-[#F2F7FD]/50 p-6 rounded-xl mb-6">
            <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
              <span class="text-[#4894B2]">✓</span>
              Как я помогаю:
            </h4>
            <p class="text-gray-700 mb-4 leading-relaxed">
              Разберёмся с глубинными причинами прокрастинации и найдём 
              эффективные стратегии для достижения целей.
            </p>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Работа со страхом неудачи</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Техники управления временем</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Работа с перфекционизмом</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Формирование мотивации</span>
              </li>
            </ul>
          </div>
          
          <button 
            onclick="openBookingModal('procrastination')"
            class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full font-semibold transition"
          >
            Записаться на консультацию
          </button>
        </div>
        
        <!-- Низкая самооценка -->
        <div id="self-esteem" class="accordion-card rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100">
          <div class="text-5xl mb-4">😔</div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Низкая самооценка и неуверенность</h3>
          
          <p class="text-gray-700 mb-6 leading-relaxed">
            Постоянная самокритика, сомнения в себе, страх не соответствовать 
            ожиданиям других людей.
          </p>
          
          <div class="mb-6">
            <h4 class="font-bold text-gray-900 mb-3">Симптомы:</h4>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Сравнение себя с другими</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Страх критики и оценки</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Синдром самозванца</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Трудности в принятии решений</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Избегание новых возможностей</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Чувство недостаточности</span>
              </li>
            </ul>
          </div>
          
          <div class="bg-[#F2F7FD]/50  p-6 rounded-xl mb-6">
            <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
              <span class="text-[#4894B2]">✓</span>
              Как я помогаю:
            </h4>
            <p class="text-gray-700 mb-4 leading-relaxed">
              Помогаем выявить и изменить негативные убеждения о себе, 
              развить самопринятие и уверенность в своих силах.
            </p>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Работа с внутренним критиком</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Развитие самосострадания</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Практика уверенного поведения</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Укрепление границ</span>
              </li>
            </ul>
          </div>
          
          <button 
            onclick="openBookingModal('self-esteem')"
            class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full font-semibold transition"
          >
            Записаться к специалисту
          </button>
        </div>
        
        <!-- Кризис -->
        <div id="crisis" class="accordion-card bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100">
          <div class="text-5xl mb-4">🌪️</div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Возрастные и жизненные кризисы</h3>
          
          <p class="text-gray-700 mb-6 leading-relaxed">
            Кризис среднего возраста, потеря смысла жизни, сложный жизненный период, 
            переоценка ценностей.
          </p>
          
          <div class="mb-6">
            <h4 class="font-bold text-gray-900 mb-3">Симптомы:</h4>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Потеря смысла и целей</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Чувство пустоты</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Переоценка прожитого</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Желание кардинальных перемен</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Растерянность</span>
              </li>
            </ul>
          </div>
          
          <div class="bg-[#F2F7FD]/50  p-6 rounded-xl mb-6">
            <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
              <span class="text-[#4894B2]">✓</span>
              Как я помогаю:
            </h4>
            <p class="text-gray-700 mb-4 leading-relaxed">
              Помогаем найти новый смысл, пройти через кризис и выйти 
              из него с обновленным видением жизни.
            </p>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Поиск личных ценностей</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Работа с экзистенциальными вопросами</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Постановка новых целей</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Принятие изменений</span>
              </li>
            </ul>
          </div>
          
          <button 
            onclick="openBookingModal('crisis')"
            class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full font-semibold transition"
          >
            Записаться к специалисту
          </button>
        </div>
        
        <!-- Отношения -->
        <div id="relationships" class="accordion-card bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100">
          <div class="text-5xl mb-4">💔</div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Сложности в отношениях</h3>
          
          <p class="text-gray-700 mb-6 leading-relaxed">
            Конфликты в паре, ревность, измены, созависимость, 
            трудности с выстраиванием границ.
          </p>
          
          <div class="mb-6">
            <h4 class="font-bold text-gray-900 mb-3">Симптомы:</h4>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Постоянные конфликты</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Недопонимание с партнером</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Потеря близости</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Токсичные паттерны</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Страх одиночества</span>
              </li>
            </ul>
          </div>
          
          <div class="bg-[#F2F7FD]/50 p-6 rounded-xl mb-6">
            <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
              <span class="text-[#4894B2]">✓</span>
              Как я помогаю:
            </h4>
            <p class="text-gray-700 mb-4 leading-relaxed">
              Работаем с паттернами отношений, помогаем улучшить коммуникацию 
              и выстроить здоровые границы.
            </p>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Улучшение коммуникации</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Работа с конфликтами</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Выстраивание границ</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Преодоление созависимости</span>
              </li>
            </ul>
          </div>
          
          <button 
            onclick="openBookingModal('relationships')"
            class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full font-semibold transition"
          >
            Записаться к специалисту
          </button>
        </div>
        
        <!-- Стресс и выгорание -->
        <div id="burnout" class="accordion-card bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100">
          <div class="text-5xl mb-4">🔥</div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Стресс и профессиональное выгорание</h3>
          
          <p class="text-gray-700 mb-6 leading-relaxed">
            Хроническая усталость на работе, потеря мотивации, 
            эмоциональное истощение.
          </p>
          
          <div class="mb-6">
            <h4 class="font-bold text-gray-900 mb-3">Симптомы:</h4>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
