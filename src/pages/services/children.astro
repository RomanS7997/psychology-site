---
// src/pages/services/children.astro
import Layout from '../../layouts/Layout.astro';
import ScrollAnimations from '../../components/ScrollAnimations.astro';
import FAQ from '../../components/FAQ.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SEO from '../../components/SEO.astro';
---

<SEO 
  title="Детский психолог в Одинцово и Лесном городке | Консультации онлайн"
  description="Детский психолог в Одинцово. Помощь детям и подросткам. Работа с истериками, агрессией, страхами, школьными проблемами. Запись онлайн."
  keywords="детский психолог Одинцово, психолог для ребенка, детская психология"
  schema="service"
/>

<Layout 
  title="Детский психолог в Одинцово и Лесном городке | Консультации онлайн"
  description="Детский психолог в Одинцово. Помощь детям и подросткам."
>

 
  <!-- Hero секция -->
  <section class="relative pt-32 pb-20 overflow-hidden" data-animate="fade">
    <!-- Фоновый градиент -->
    <div class="absolute inset-0 bg-gradient-to-br from-[rgba(230,215,205,0.2)] via-[rgba(215,198,188,0.26)] to-[rgba(200,180,170,0.35)]"></div>
    
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        
        <!-- Текст -->
        <div>
          <div class="inline-block px-4 py-2 bg-[#F2F7FD] text-gray-900 rounded-full font-semibold mb-4">
            Для родителей
          </div>
          
          <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-[#4894B2] to-[#18698F] bg-clip-text text-transparent">
            Поможем вашему ребенку справиться с трудностями
          </h1>
          
          <p class="text-xl text-gray-700 mb-6 leading-relaxed">
            Детский психолог в игровой форме поможет ребенку понять свои эмоции, 
            справиться со страхами и наладить отношения с окружающими
          </p>
          
          <div class="flex flex-wrap gap-4 mb-8">
           <button onclick="openBookingModal()" class="px-8 py-4 bg-[#4894B2] hover:bg-[#18698F]  hover:from-teal-700 hover:to-blue-700 text-white rounded-full font-semibold transition shadow-lg hover:shadow-xl hover:scale-105" data-astro-source-file="C:/Users/romas/OneDrive/Рабочий стол/famproject/psychology-site/src/pages/services/adult.astro" data-astro-source-loc="45:14">
Записаться на консультацию
</button> <button onclick="openBookingModal('specialist')" class="px-8 py-4 bg-white hover:bg-gray-50 text-[#4894B2] border-2 border-teal-600 rounded-full font-semibold transition" data-astro-source-file="C:/Users/romas/OneDrive/Рабочий стол/famproject/psychology-site/src/pages/services/adult.astro" data-astro-source-loc="51:14">
Первичная консультация
</button> 
          </div>
          
          <!-- Быстрые факты -->
          <div class="grid grid-cols-3 gap-6" data-stagger>
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4894B2] mb-2">5-18</div>
              <div class="text-sm text-gray-600">возраст<br/>детей</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4894B2] mb-2">55 мин</div>
              <div class="text-sm text-gray-600">длительность<br/>сессии</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4894B2] mb-2" data-counter="100" data-suffix="%">0</div>
              <div class="text-sm text-gray-600">родителей видят<br/>результат</div>
            </div>
          </div>
        </div>
        
       <!-- Изображение -->
        <div class="flex justify-center lg:justify-end " >
        <div class="relative w-full max-w-md">
          <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-2xl">
            <img 
              src="/images/services/child-therapy.jpg" 
              alt="Консультация психолога" 
              class="w-full h-auto"
            />
          
          <!-- Декоративные элементы -->
          <div class="absolute -top-6 -right-6 w-24 h-24 bg-[#F2F7FD] rounded-full opacity-30 blur-2xl"></div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-[#F2F7FD] rounded-full opacity-30 blur-2xl"></div>
        </div>
        
      </div>
    </div>
  </section>

 <Breadcrumbs 
    items={[
      { label: 'Главная', href: '/' },
      { label: 'Услуги', href: '/#services' },
      { label: 'Занятия с детьми' }
    ]}
  />
  </div><!-- 
  С чем мы работаем -->
  <section id="what-we-help" class="py-20 bg-white" data-animate="fade">
    <div class="container mx-auto px-4 lg:px-8">
      <h2 class="text-4xl md:text-5xl font-bold text-center mb-4">
        С чем мы помогаем детям
      </h2>
      <p class="text-center text-gray-600 text-lg mb-16 max-w-2xl mx-auto">
        Распознайте проблему вашего ребенка и узнайте, как мы можем помочь
      </p>
      
      <!-- Сетка проблем -->
      <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto">
        
        <!-- Страхи и тревоги -->
        <div class="bg-white accordion-card  rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 cursor-pointer">
          <div class="text-5xl mb-4">😨</div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Страхи, тревожность, фобии</h3>
          
          <p class="text-gray-700 mb-6 leading-relaxed">
            Страх темноты, одиночества, школы, общения. Ночные кошмары, 
            нежелание оставаться одному.
          </p>
          
          <div class="mb-6">
            <h4 class="font-bold text-gray-900 mb-3">Признаки:</h4>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Отказывается спать один</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Цепляется за родителей</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Плачет перед школой</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Жалуется на кошмары</span>
              </li>
            </ul>
          </div>
          
          <div class="bg-[#F2F7FD]/50  p-6 rounded-xl mb-6">
            <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
              <span class="text-[#4894B2]">✓</span>
              Как мы помогаем:
            </h4>
            <p class="text-gray-700 mb-4 leading-relaxed">
              Используем игровую терапию и арт-терапию. Ребенок "проигрывает" 
              свои страхи через рисунки и игрушки, учится справляться с тревогой.
            </p>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Техники работы со страхами</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Сказкотерапия</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Дыхательные упражнения</span>
              </li>
            </ul>
          </div>
          
          <button 
            onclick="openBookingModal('fears')"
            class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full font-semibold transition"
          >
            Записаться к детскому психологу
          </button>
        </div>
        
        <!-- Агрессия и истерики -->
        <div class="bg-white accordion-card rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 cursor-pointer">
          <div class="text-5xl mb-4">😡</div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Агрессия, истерики, непослушание</h3>
          
          <p class="text-gray-700 mb-6 leading-relaxed">
            Частые вспышки гнева, драки с другими детьми, неконтролируемые истерики, 
            разрушительное поведение.
          </p>
          
          <div class="mb-6">
            <h4 class="font-bold text-gray-900 mb-3">Признаки:</h4>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Бьет родителей, детей</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Ломает игрушки</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Кричит, закатывает истерики</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2] mt-1">•</span>
                <span>Не слушается</span>
              </li>
            </ul>
          </div>
          
          <div class="bg-[#F2F7FD]/50  p-6 rounded-xl mb-6">
            <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
              <span class="text-[#4894B2]">✓</span>
              Как мы помогаем:
            </h4>
            <p class="text-gray-700 mb-4 leading-relaxed">
              Учим ребенка распознавать свои эмоции и выражать их безопасным способом. 
              Работаем с причинами агрессии.
            </p>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Обучение эмоциональной регуляции</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Игровая терапия агрессии</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[#4894B2]">✓</span>
                <span>Работа с родителями</span>
              </li>
            </ul>
          </div>
          
          <button 
            onclick="openBookingModal('aggression')"
            class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#4894B2] text-white rounded-full font-semibold transition"
