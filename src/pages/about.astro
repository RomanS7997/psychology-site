---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SEO from '../components/SEO.astro';
---

<SEO 
  title="Обо мне - Кабинет психолога в Одинцово | Ляпина Юлия"
  description="О кабинете психолога Ляпиной Юлии в Одинцово. Моя команда, 15 лет опыта работы, подход к клиентам."
  keywords="психолог Одинцово, о кабинете, команда специалистов"
  schema="organization"
/>

<Layout 
  title="Обо мне - Кабинет психолога в Одинцово | Ляпина Юлия"
  description="О кабинете психолога Ляпиной Юлии в Одинцово."
>

  <Breadcrumbs 
    items={[
      { label: 'Главная', href: '/' },
      { label: 'О нас' }
    ]}
  />

  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden bg-gradient-to-br from-teal-50 via-blue-50 to-purple-50" data-animate="fade">
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-[#4894B2] to-[#18698F] bg-clip-text text-transparent">
          Обо мне
        </h1>
        <p class="text-xl text-gray-700 mb-8">
          Кабинет психолога Ляпина Юлия — это пространство, 
          где вы можете получить профессиональную помощь и поддержку 
          в решении любых жизненных трудностей
        </p>
      </div>
    </div>
  </section>

  <!-- Обо мне -->
  <section class="relative py-20 bg-gradient-to-br from-[#F2F7FD] via-white to-white overflow-hidden" data-animate="slide-up">
    <div class="absolute top-20 right-10 w-56 h-56 bg-[#4894B2]/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 left-10 w-48 h-48 bg-[#d9797d]/10 rounded-full blur-3xl"></div>
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-4xl mx-auto">
        
        <div class="mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-6">Моя история</h2>
          <div class="prose prose-lg text-gray-700 space-y-4">
            <p>
              Меня зовут Юлия! Благодаря практике и разнообразным методикам, я работаю
              с детьми, подростками и взрослыми.
            </p>
            <p>В работе использую:</p>
            <ul class="list-disc pl-6 space-y-1">
              <li>Арт-терапию</li>
              <li>Когнитивно-поведенческую терапию (КПТ)</li>
              <li>Метафорические ассоциативные карты (МАК)</li>
              <li>ДПДГ (десенсибилизация и переработка движением глаз)</li>
              <li>Расстановки</li>
              <li>Системный подход</li>
            </ul>
            <p>
              За годы работы я помогла сотням клиентов. Постоянно обучаюсь,
              придерживаюсь научного подхода и честно отношусь к своей работе.
            </p>
            <p>
              Моя цель — не держать клиентов в терапии годами, а научить их самостоятельно
              справляться с трудностями с помощью техник, упражнений и осознанности.
              Результаты подтверждают эффективность моего подхода.
            </p>
            <p>
              Все мои программы созданы с учётом реальных запросов, например, курсы для
              детей «Азбука общения» и «Умники и умницы».
            </p>
            <p>
              Многие родители понимают важность мягкой подготовки ребёнка к школе и помощи
              в контакте с чувствами — это основа для успешной жизни. Мне приятно быть
              частью их счастья и развития.
            </p>
          </div>
        </div>

        <!-- Статистика -->
        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="text-center">
            <div class="text-5xl font-bold text-[#4894B2] mb-2">15+</div>
            <div class="text-gray-600">лет опыта</div>
          </div>
          <div class="text-center">
            <div class="text-5xl font-bold text-[#4894B2] mb-2">100%</div>
            <div class="text-gray-600">положительных результатов</div>
          </div>
          <div class="text-center">
            <div class="text-5xl font-bold text-[#4894B2] mb-2">95%</div>
            <div class="text-gray-600">рекомендуют друзьям</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Мои ценности -->
  <section class="py-20 bg-gray-50" data-animate="fade">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-6xl mx-auto">
        
        <h2 class="text-4xl font-bold text-gray-900 mb-12 text-center">Мои ценности</h2>
        
        <div class="grid md:grid-cols-3 gap-8">
          
          <!-- Ценность 1 -->
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition">
            <div class="text-5xl mb-4">🤝</div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Доверие и конфиденциальность</h3>
            <p class="text-gray-700">
              Всё, что происходит на сессиях, остаётся между вами и мной. 
              Я строго соблюдаю принципы конфиденциальности.
            </p>
          </div>

          <!-- Ценность 2 -->
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition">
            <div class="text-5xl mb-4">🎓</div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Профессионализм</h3>
            <p class="text-gray-700">
              Высшее психологическое образование, 
              регулярное обучение и повышение квалификации.
            </p>
          </div>

          <!-- Ценность 3 -->
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition">
            <div class="text-5xl mb-4">🔬</div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Научный подход</h3>
            <p class="text-gray-700">
              Использую методы с доказанной эффективностью: арт-терапию, КПТ,
              МАК, ДПДГ, расстановки и системный подход.
            </p>
          </div>

          <!-- Ценность 4 -->
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition">
            <div class="text-5xl mb-4">❤️</div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Эмпатия и уважение</h3>
            <p class="text-gray-700">
              Отношусь к каждому клиенту с уважением и пониманием, 
              создавая безопасное пространство для работы с трудностями.
            </p>
          </div>

          <!-- Ценность 5 -->
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition">
            <div class="text-5xl mb-4">🎯</div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Индивидуальный подход</h3>
            <p class="text-gray-700">
              Каждый человек уникален. Подбираю методы работы 
              под ваши потребности и особенности.
            </p>
          </div>

          <!-- Ценность 6 -->
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition">
            <div class="text-5xl mb-4">🌱</div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Ориентация на результат</h3>
            <p class="text-gray-700">
              Не просто слушаю — помогаю вам достичь конкретных 
              изменений и улучшить качество вашей жизни.
            </p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Мой подход -->
  <section class="py-20 bg-white" data-animate="slide-up">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-4xl mx-auto">
        
        <h2 class="text-4xl font-bold text-gray-900 mb-8 text-center">Мой подход к работе</h2>
        
        <div class="space-y-8">
          
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-teal-100 text-[#4894B2] flex items-center justify-center text-xl font-bold">
              1
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Первичная консультация</h3>
              <p class="text-gray-700">
                На первой встрече мы знакомимся, формируем ваш запрос, определяем цели и маршрут работы.
              </p>
            </div>
          </div>

          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-[#F2F7FD] text-[#4894B2] flex items-center justify-center text-xl font-bold">
              2
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">План работы</h3>
              <p class="text-gray-700">
                Вместе с вами составляю индивидуальный план работы. Обсуждаем, какие методы будут использоваться и сколько сессий может потребоваться.
              </p>
            </div>
          </div>

          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-[#F2F7FD] text-[#4894B2] flex items-center justify-center text-xl font-bold">
              3
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Работа с вашим запросом</h3>
              <p class="text-gray-700">
                Регулярные встречи, на которых работаем с вашим запросом,
                используя научно обоснованные методы. Между сессиями могут быть домашние задания.
              </p>
            </div>
          </div>

          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-[#F2F7FD] text-[#4894B2] flex items-center justify-center text-xl font-bold">
              4
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Оценка прогресса</h3>
              <p class="text-gray-700">
                В ходе работы оцениваем прогресс и корректируем план при необходимости.
                Важно, чтобы вы видели изменения и чувствовали улучшения.
              </p>
            </div>
          </div>

          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-[#F2F7FD] text-[#4894B2] flex items-center justify-center text-xl font-bold">
              5
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Завершение работы</h3>
              <p class="text-gray-700">
                Когда запрос решён, планируем завершение работы. При необходимости
                вы всегда можете вернуться на поддерживающие сессии.
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Методы работы -->
  <section class="py-20 bg-gradient-to-br from-teal-50 to-blue-50" data-animate="fade">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-4xl mx-auto">
        
        <h2 class="text-4xl font-bold text-gray-900 mb-8 text-center">Методы, которые я использую</h2>
        
        <div class="grid md:grid-cols-2 gap-6">
          
          <div class="bg-white rounded-xl p-6 shadow-md">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Арт-терапия</h3>
            <p class="text-gray-700 text-sm">
              Направление, основанное на использовании творчества для улучшения психоэмоционального состояния и раскрытия внутренних ресурсов.
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-md">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Когнитивно-поведенческая терапия (КПТ)</h3>
            <p class="text-gray-700 text-sm">
              Краткосрочный метод психотерапии, сочетающий работу с мышлением и поведением.
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-md">
            <h3 class="text-lg font-bold text-gray-900 mb-2">МАК (Метафорические ассоциативные карты)</h3>
            <p class="text-gray-700 text-sm">
              Проективный инструмент, помогающий обойти защиты и получить доступ к подсознательным процессам.
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-md">
            <h3 class="text-lg font-bold text-gray-900 mb-2">ДПДГ (Десенсибилизация движением глаз)</h3>
            <p class="text-gray-700 text-sm">
              Метод для работы с травмами и стрессовыми переживаниями.
              Помогает переработать болезненный опыт и снизить его влияние.
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-md">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Расстановки</h3>
            <p class="text-gray-700 text-sm">
              Метод в психологии, помогающий проработать личные проблемы через визуализацию отношений в разных системах (семья, род, работа и т.д.).
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-md">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Системный подход</h3>
            <p class="text-gray-700 text-sm">
              Работа с семейными системами. Помогает увидеть скрытые динамики
              в отношениях и найти ресурсы для изменений.
            </p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-to-br from-[#4894B2] to-[#18698F] text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-white rounded-full opacity-10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#F2F7FD] rounded-full opacity-10 blur-3xl"></div>
    
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-bold mb-6">
          Готовы записаться?
        </h2>
        <p class="text-xl mb-8 opacity-90">
          Запишитесь на первую консультацию и сделайте первый шаг к изменениям
        </p>

        <div class="flex flex-wrap gap-4 justify-center">
          <button
            onclick="window.location.href='/#booking'"
            class="px-12 py-5 bg-white hover:bg-gray-100 text-[#4894B2] rounded-full font-bold transition shadow-xl hover:shadow-2xl text-lg"
          >
            Записаться на консультацию
          </button>
        </div>
      </div>
    </div>
  </section>

  <ScrollAnimations />
</Layout>
