---
// Компонент для добавления scroll анимаций на всех страницах
---

<script is:inline>
  // Функция для инициализации анимаций
  function initScrollAnimations() {
    // Настройка Intersection Observer
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
          
          // Для stagger эффекта (элементы появляются по очереди)
          if (entry.target.hasAttribute('data-stagger')) {
            const children = entry.target.children;
            Array.from(children).forEach((child, index) => {
              setTimeout(() => {
                child.classList.add('animate-in');
              }, index * 250); // 250ms задержка между элементами
            });
          }
          
          // Для счетчиков внутри элемента
          const counters = entry.target.querySelectorAll('[data-counter]');
          counters.forEach(counter => {
            animateCounter(counter);
          });
          
          // Если сам элемент - счетчик
          if (entry.target.hasAttribute('data-counter')) {
            animateCounter(entry.target);
          }
          
          // Для прогресс-баров
          const progressBars = entry.target.querySelectorAll('[data-progress-bar]');
          progressBars.forEach(bar => {
            animateProgressBar(bar);
          });
          
          // Для линий прогресса (timeline)
          const progressLines = entry.target.querySelectorAll('[data-progress-line]');
          progressLines.forEach(line => {
            animateProgressLine(line);
          });
          
          // Отключаем наблюдение после анимации
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Находим все элементы для анимации
    const animatedElements = document.querySelectorAll('[data-animate], [data-stagger]');
    animatedElements.forEach(el => observer.observe(el));
  }

  // Анимация прогресс-баров
  function animateProgressBar(element) {
    const targetWidth = element.getAttribute('data-progress-bar');
    setTimeout(() => {
      element.style.width = targetWidth + '%';
    }, 100);
  }

  // Анимация линии прогресса (для timeline)
  function animateProgressLine(element) {
    setTimeout(() => {
      element.style.height = '100%';
    }, 200);
  }

  // Анимация счетчиков
  function animateCounter(element) {
    const targetStr = element.getAttribute('data-counter');
    const isDecimal = targetStr.includes('.');
    const target = parseFloat(targetStr);
    const duration = 2000; // 2 секунды
    const start = 0;
    const increment = target / (duration / 16); // 60 FPS
    let current = start;

    const timer = setInterval(() => {
      current += increment;
      if (current >= target) {
        if (isDecimal) {
          element.textContent = target.toFixed(1) + (element.getAttribute('data-suffix') || '');
        } else {
          element.textContent = Math.floor(target) + (element.getAttribute('data-suffix') || '');
        }
        clearInterval(timer);
      } else {
        if (isDecimal) {
          element.textContent = current.toFixed(1) + (element.getAttribute('data-suffix') || '');
        } else {
          element.textContent = Math.floor(current) + (element.getAttribute('data-suffix') || '');
        }
      }
    }, 16);
  }

  // Инициализация при загрузке страницы
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollAnimations);
  } else {
    initScrollAnimations();
  }

  // Реинициализация для SPA navigation (если используется)
  document.addEventListener('astro:page-load', initScrollAnimations);
</script>

<style is:global>
  /* Fade in */
  [data-animate="fade"] {
    opacity: 0;
    transition: opacity 0.9s ease-out;
  }
  
  [data-animate="fade"].animate-in {
    opacity: 1;
  }

  /* Slide up */
  [data-animate="slide-up"] {
    opacity: 0;
    transform: translateY(50px);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out;
  }
  
  [data-animate="slide-up"].animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  /* Slide left */
  [data-animate="slide-left"] {
    opacity: 0;
    transform: translateX(30px);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out;
  }
  
  [data-animate="slide-left"].animate-in {
    opacity: 1;
    transform: translateX(0);
  }

  /* Slide right */
  [data-animate="slide-right"] {
    opacity: 0;
    transform: translateX(-30px);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out;
  }
  
  [data-animate="slide-right"].animate-in {
    opacity: 1;
    transform: translateX(0);
  }

  /* Scale */
  [data-animate="scale"] {
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out;
  }
  
  [data-animate="scale"].animate-in {
    opacity: 1;
    transform: scale(1);
  }

  /* Stagger - контейнер видим, дети скрыты */
  [data-stagger] {
    opacity: 1;
  }

  [data-stagger] > * {
    opacity: 0;
    transform: translateY(50px);
    transition: opacity 1s ease-out, transform 1s ease-out;
  }

  [data-stagger] > *.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  /* Задержки для разных элементов */
  [data-delay="100"] {
    transition-delay: 0.1s;
  }
  
  [data-delay="200"] {
    transition-delay: 0.2s;
  }
  
  [data-delay="300"] {
    transition-delay: 0.3s;
  }
  
  [data-delay="400"] {
    transition-delay: 0.4s;
  }
</style>
