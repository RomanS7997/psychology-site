---
// src/components/AutoGallerySlider.astro
// Универсальный автослайдер с лайтбоксом для галерей

interface Props {
  images: {
    src: string;
    alt: string;
    caption?: string;
  }[];
  title?: string;
  subtitle?: string;
  autoplayDelay?: number; // в миллисекундах, по умолчанию 4000
  accentColor?: string; // для кастомизации цвета (blue, pink, purple)
}

const { 
  images, 
  title = "Как проходят занятия", 
  subtitle = "Фотографии с наших занятий",
  autoplayDelay = 4000,
  accentColor = "blue" 
} = Astro.props;

// Генерируем уникальный ID для этого слайдера
const sliderId = `slider-${Math.random().toString(36).substr(2, 9)}`;

// Цветовые схемы для разных акцентов
const colorSchemes = {
  blue: {
    gradient: 'from-[#4894B2] to-[#18698F]',
    text: 'text-[#4894B2]',
    bg: 'bg-[#4894B2]',
    hover: 'hover:bg-[#18698F]'
  },
  pink: {
    gradient: 'from-[#4894B2] to-[#18698F]',
    text: 'text-[#4894B2]',
    bg: 'bg-[#4894B2]',
    hover: 'hover:bg-[#18698F]'
  },
  purple: {
    gradient: 'from-[#4894B2] to-[#18698F]',
    text: 'text-[#4894B2]',
    bg: 'bg-[#4894B2]',
    hover: 'hover:bg-[#18698F]'
  },
  orange: {
    gradient: 'from-[#4894B2] to-[#18698F]',
    text: 'text-[#4894B2]',
    bg: 'bg-[#4894B2]',
    hover: 'hover:bg-[#18698F]'
  }
};

const colors = colorSchemes[accentColor as keyof typeof colorSchemes] || colorSchemes.blue;
---

<!-- Секция с галереей -->
<section class="py-20 bg-gradient-to-br from-gray-50 to-white">
  <div class="container mx-auto px-4 lg:px-8">
    
    <!-- Заголовок -->
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold mb-4 bg-gradient-to-r {colors.gradient} bg-clip-text text-transparent">
        {title}
      </h2>
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">
        {subtitle}
      </p>
    </div>

    <!-- Слайдер -->
    <div class="max-w-6xl mx-auto">
      <div id={sliderId} class="relative rounded-3xl overflow-hidden shadow-2xl bg-gray-900">
        
        <!-- Контейнер слайдов -->
        <div class="relative h-[400px] md:h-[600px]">
          {images.map((image, index) => (
            <div 
              class={`absolute inset-0 transition-opacity duration-700 ease-in-out ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
              data-slide={index}
            >
              <img 
                src={image.src}
                alt={image.alt}
                class="w-full h-full object-cover cursor-pointer hover:scale-105 transition-transform duration-500"
                loading={index < 2 ? 'eager' : 'lazy'}
                onclick={`openLightbox('${sliderId}', ${index})`}
              />
              
              <!-- Градиентный overlay для текста -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
              
              <!-- Подпись -->
              {image.caption && (
                <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
                  <p class="text-white text-lg md:text-xl font-semibold drop-shadow-lg">
                    {image.caption}
                  </p>
                </div>
              )}
            </div>
          ))}
        </div>

        <!-- Навигационные стрелки -->
        <button 
          class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/90 hover:bg-white p-3 rounded-full shadow-lg transition-all duration-300 hover:scale-110 z-10"
          onclick={`navigateSlide('${sliderId}', -1)`}
          aria-label="Предыдущий слайд"
        >
          <svg class="w-6 h-6 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>
        
        <button 
          class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/90 hover:bg-white p-3 rounded-full shadow-lg transition-all duration-300 hover:scale-110 z-10"
          onclick={`navigateSlide('${sliderId}', 1)`}
          aria-label="Следующий слайд"
        >
          <svg class="w-6 h-6 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
          </svg>
        </button>

        <!-- Индикаторы -->
        <div class="absolute bottom-6 left-0 right-0 flex justify-center gap-2 z-10">
          {images.map((_, index) => (
            <button
              class={`w-2.5 h-2.5 rounded-full transition-all duration-300 ${index === 0 ? `${colors.bg} w-8` : 'bg-white/60 hover:bg-white/80'}`}
              onclick={`goToSlide('${sliderId}', ${index})`}
              data-indicator={index}
              aria-label={`Перейти к слайду ${index + 1}`}
            ></button>
          ))}
        </div>

        <!-- Счетчик слайдов -->
        <div class="absolute top-6 right-6 bg-black/60 text-white px-4 py-2 rounded-full text-sm font-semibold backdrop-blur-sm">
          <span data-current-slide>1</span> / <span>{images.length}</span>
        </div>

        <!-- Кнопка "Открыть галерею" -->
        <button 
          class={`absolute top-6 left-6 bg-gradient-to-r ${colors.gradient} hover:opacity-90 text-white px-6 py-3 rounded-full font-semibold transition-all duration-300 shadow-lg hover:shadow-xl flex items-center gap-2`}
          onclick={`openLightbox('${sliderId}', getCurrentSlide('${sliderId}'))`}
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          Открыть галерею
        </button>
      </div>

      <!-- Информация под слайдером -->
      <div class="mt-8 text-center">
        <p class="text-gray-600">
          <span class={`${colors.text} font-semibold`}>💡 Совет:</span> 
          Нажмите на фото или кнопку "Открыть галерею", чтобы просмотреть все изображения в полноэкранном режиме
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Лайтбокс -->
<div id={`lightbox-${sliderId}`} class="fixed inset-0 bg-black/95 z-[100] hidden items-center justify-center p-4">
  <!-- Кнопка закрытия -->
  <button 
    class="absolute top-6 right-6 bg-white/10 hover:bg-white/20 text-white p-3 rounded-full transition-all duration-300 backdrop-blur-sm z-10"
    onclick={`closeLightbox('${sliderId}')`}
    aria-label="Закрыть галерею"
  >
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>

  <!-- Контейнер изображения -->
  <div class="relative w-full h-full flex items-center justify-center">
    <img 
      id={`lightbox-image-${sliderId}`}
      src="" 
      alt=""
      class="max-w-full max-h-full object-contain"
    />

    <!-- Подпись в лайтбоксе -->
    <div id={`lightbox-caption-${sliderId}`} class="absolute bottom-8 left-0 right-0 text-center">
      <p class="text-white text-xl font-semibold drop-shadow-2xl bg-black/50 inline-block px-6 py-3 rounded-full backdrop-blur-sm">
      </p>
    </div>
  </div>

  <!-- Навигация в лайтбоксе -->
  <button 
    class="absolute left-6 top-1/2 -translate-y-1/2 bg-white/10 hover:bg-white/20 text-white p-4 rounded-full transition-all duration-300 backdrop-blur-sm"
    onclick={`navigateLightbox('${sliderId}', -1)`}
    aria-label="Предыдущее фото"
  >
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path>
    </svg>
  </button>
  
  <button 
    class="absolute right-6 top-1/2 -translate-y-1/2 bg-white/10 hover:bg-white/20 text-white p-4 rounded-full transition-all duration-300 backdrop-blur-sm"
    onclick={`navigateLightbox('${sliderId}', 1)`}
    aria-label="Следующее фото"
  >
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
    </svg>
  </button>

  <!-- Счетчик в лайтбоксе -->
  <div class="absolute top-6 left-1/2 -translate-x-1/2 bg-white/10 text-white px-6 py-3 rounded-full text-lg font-semibold backdrop-blur-sm">
    <span id={`lightbox-counter-${sliderId}`}>1</span> / {images.length}
  </div>
</div>

<script define:vars={{ sliderId, images, autoplayDelay }}>
  (function() {
    let currentSlide = 0;
    let autoplayInterval;
    let lightboxIndex = 0;
    const totalSlides = images.length;

    // Получить текущий слайд
    window[`getCurrentSlide`] = function(id) {
      if (id === sliderId) return currentSlide;
    };

    // Показать конкретный слайд
    function showSlide(index) {
      const slides = document.querySelectorAll(`#${sliderId} [data-slide]`);
      const indicators = document.querySelectorAll(`#${sliderId} [data-indicator]`);
      const currentSlideDisplay = document.querySelector(`#${sliderId} [data-current-slide]`);

      // Скрыть все слайды
      slides.forEach(slide => slide.classList.replace('opacity-100', 'opacity-0'));
      
      // Сбросить все индикаторы
      indicators.forEach((indicator, i) => {
        if (i === index) {
          indicator.classList.add('w-8');
          indicator.classList.remove('bg-white/60');
          // Добавляем цвет в зависимости от акцента
          const colorClass = indicator.className.match(/bg-\w+-\d+/)?.[0];
          if (!colorClass) indicator.className += ' bg-[#4894B2]';
        } else {
          indicator.classList.remove('w-8');
          indicator.classList.add('bg-white/60');
          // Удаляем цветные классы
          indicator.className = indicator.className.replace(/bg-\w+-\d+/g, 'bg-white/60');
        }
      });

      // Показать нужный слайд
      slides[index]?.classList.replace('opacity-0', 'opacity-100');
      
      // Обновить счетчик
      if (currentSlideDisplay) {
        currentSlideDisplay.textContent = index + 1;
      }

      currentSlide = index;
    }

    // Навигация по слайдам
    window[`navigateSlide`] = function(id, direction) {
      if (id !== sliderId) return;
      
      stopAutoplay();
      let newIndex = currentSlide + direction;
      
      if (newIndex < 0) newIndex = totalSlides - 1;
      if (newIndex >= totalSlides) newIndex = 0;
      
      showSlide(newIndex);
      startAutoplay();
    };

    // Перейти к конкретному слайду
    window[`goToSlide`] = function(id, index) {
      if (id !== sliderId) return;
      
      stopAutoplay();
      showSlide(index);
      startAutoplay();
    };

    // Автопроигрывание
    function startAutoplay() {
      stopAutoplay();
      autoplayInterval = setInterval(() => {
        let nextIndex = currentSlide + 1;
        if (nextIndex >= totalSlides) nextIndex = 0;
        showSlide(nextIndex);
      }, autoplayDelay);
    }

    function stopAutoplay() {
      if (autoplayInterval) {
        clearInterval(autoplayInterval);
      }
    }

    // Открыть лайтбокс
    window[`openLightbox`] = function(id, index) {
      if (id !== sliderId) return;
      
      lightboxIndex = index;
      const lightbox = document.getElementById(`lightbox-${sliderId}`);
      const lightboxImage = document.getElementById(`lightbox-image-${sliderId}`);
      const lightboxCaption = document.getElementById(`lightbox-caption-${sliderId}`);
      const lightboxCounter = document.getElementById(`lightbox-counter-${sliderId}`);

      if (lightbox && lightboxImage) {
        lightboxImage.src = images[index].src;
        lightboxImage.alt = images[index].alt;
        
        if (lightboxCaption && images[index].caption) {
          lightboxCaption.querySelector('p').textContent = images[index].caption;
          lightboxCaption.classList.remove('hidden');
        } else if (lightboxCaption) {
          lightboxCaption.classList.add('hidden');
        }

        if (lightboxCounter) {
          lightboxCounter.textContent = index + 1;
        }

        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
        
        stopAutoplay();
      }
    };

    // Закрыть лайтбокс
    window[`closeLightbox`] = function(id) {
      if (id !== sliderId) return;
      
      const lightbox = document.getElementById(`lightbox-${sliderId}`);
      if (lightbox) {
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
        document.body.style.overflow = '';
        
        startAutoplay();
      }
    };

    // Навигация в лайтбоксе
    window[`navigateLightbox`] = function(id, direction) {
      if (id !== sliderId) return;
      
      lightboxIndex += direction;
      
      if (lightboxIndex < 0) lightboxIndex = totalSlides - 1;
      if (lightboxIndex >= totalSlides) lightboxIndex = 0;
      
      const lightboxImage = document.getElementById(`lightbox-image-${sliderId}`);
      const lightboxCaption = document.getElementById(`lightbox-caption-${sliderId}`);
      const lightboxCounter = document.getElementById(`lightbox-counter-${sliderId}`);

      if (lightboxImage) {
        lightboxImage.src = images[lightboxIndex].src;
        lightboxImage.alt = images[lightboxIndex].alt;
      }

      if (lightboxCaption && images[lightboxIndex].caption) {
        lightboxCaption.querySelector('p').textContent = images[lightboxIndex].caption;
        lightboxCaption.classList.remove('hidden');
      } else if (lightboxCaption) {
        lightboxCaption.classList.add('hidden');
      }

      if (lightboxCounter) {
        lightboxCounter.textContent = lightboxIndex + 1;
      }
    };

    // Закрытие лайтбокса по ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        window[`closeLightbox`](sliderId);
      }
      // Навигация стрелками в лайтбоксе
      const lightbox = document.getElementById(`lightbox-${sliderId}`);
      if (lightbox && !lightbox.classList.contains('hidden')) {
        if (e.key === 'ArrowLeft') {
          window[`navigateLightbox`](sliderId, -1);
        } else if (e.key === 'ArrowRight') {
          window[`navigateLightbox`](sliderId, 1);
        }
      }
    });

    // Пауза при наведении
    const sliderElement = document.getElementById(sliderId);
    if (sliderElement) {
      sliderElement.addEventListener('mouseenter', stopAutoplay);
      sliderElement.addEventListener('mouseleave', startAutoplay);
    }

    // Запуск автопроигрывания
    startAutoplay();
  })();
</script>

<style>
  /* Плавная анимация для слайдов */
  [data-slide] {
    transition: opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Оптимизация для будущих анимаций */
  img {
    will-change: transform;
  }

  /* Прелоадер для изображений */
  img[loading="lazy"] {
    opacity: 0;
    animation: fadeIn 0.5s ease-in forwards;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }
</style>
