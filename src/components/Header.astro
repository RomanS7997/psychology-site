---
// src/components/Header.astro - ОБНОВЛЕННЫЙ
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="flex items-center justify-between h-24">
      
      <!-- Logo -->
      <div class="flex items-center gap-3">
        <a href="/psychology-site/" class="flex items-center">
          <img src="/psychology-site/images/logo.png" alt="Кабинет психолога Ляпина Юлия" class="h-16 w-auto" />
        </a>
      </div>

      <!-- Navigation + Contacts -->
      <div class="hidden lg:flex items-center gap-6">
        
        <!-- Navigation Links -->
        <nav class="flex items-center gap-6">
          <!-- Выпадающее меню Услуги -->
          <div class="relative group">
            <button class="text-gray-700 hover:text-[#d9797d] transition flex items-center gap-1">
              Услуги
              <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            
            <!-- Dropdown -->
            <div class="absolute left-0 top-full mt-2 w-64 bg-white rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 border border-gray-100">
              <div class="py-2">
                <a href="/psychology-site/services/adult" class="block px-6 py-3 text-gray-700 hover:bg-[#F2F7FD] hover:text-[#4894B2] transition">
                  <div class="font-semibold">Консультирование взрослых</div>
                  <div class="text-xs text-gray-500">Работа с тревогой, отношениями, самооценкой</div>
                </a>
                <a href="/psychology-site/services/children" class="block px-6 py-3 text-gray-700 hover:bg-[#F2F7FD] hover:text-[#4894B2] transition border-t border-gray-100">
                  <div class="font-semibold">Занятия с детьми</div>
                  <div class="text-xs text-gray-500">Помощь детям и подросткам 5-18 лет</div>
                </a>
              </div>
            </div>
          </div>
          
          <!-- Выпадающее меню Программы -->
          <div class="relative group">
            <button class="text-gray-700 hover:text-[#d9797d] transition flex items-center gap-1">
              Программы
              <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            
            <!-- Dropdown -->
            <div class="absolute left-0 top-full mt-2 w-64 bg-white rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 border border-gray-100">
              <div class="py-2">
                <a href="/psychology-site/services/school-prep" class="block px-6 py-3 text-gray-700 hover:bg-[#F2F7FD] hover:text-[#4894B2] transition">
                  <div class="font-semibold">Подготовка к школе</div>
                  <div class="text-xs text-gray-500">Комплексная программа • 6-7 лет</div>
                </a>
                <a href="/psychology-site/programs/umniky" class="block px-6 py-3 text-gray-700 hover:bg-[#F2F7FD] hover:text-[#4894B2] transition border-t border-gray-100">
                  <div class="font-semibold">Умники и умницы</div>
                  <div class="text-xs text-gray-500">Развитие и подготовка • 5-7 лет</div>
                </a>
                <a href="/psychology-site/programs/azbuka" class="block px-6 py-3 text-gray-700 hover:bg-[#F2F7FD] hover:text-[#4894B2] transition border-t border-gray-100">
                  <div class="font-semibold">Азбука общения</div>
                  <div class="text-xs text-gray-500">Развитие EQ • 5-9 лет</div>
                </a>
              </div>
            </div>
          </div>
          
          <a href="/psychology-site/specialists" class="text-gray-700 hover:text-[#d9797d] transition">Специалисты</a>
          <a href="/psychology-site/reviews" class="text-gray-700 hover:text-[#d9797d] transition">Отзывы</a>
          <a href="/psychology-site/about" class="text-gray-700 hover:text-[#d9797d] transition">Обо мне</a>
          <a href="/psychology-site/blog" class="text-gray-700 hover:text-[#d9797d] transition">Блог</a>
          <a href="/psychology-site/contact" class="text-gray-700 hover:text-[#d9797d] transition">Контакты</a>
        </nav>

        <!-- Divider -->
        <div class="w-px h-10 bg-gray-200"></div>

        <!-- Contacts -->
        <div class="flex items-center gap-4">
          <!-- Phone -->
          <a 
            href="tel:+79991234567" 
            class="flex items-center gap-2 text-gray-900 hover:text-[#4894B2] transition group"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <span class="font-semibold hidden xl:inline">+7 (999) 123-45-67</span>
          </a>

          <!-- Messengers -->
          <div class="flex items-center gap-2">
            <!-- WhatsApp -->
            <a 
              href="https://wa.me/79991234567" 
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-[#25D366] hover:bg-[#20BA5A] flex items-center justify-center transition group"
              title="WhatsApp"
            >
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
            </a>

            <!-- Telegram -->
            <a 
              href="https://t.me/username" 
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-[#229ED9] hover:bg-[#1E88C5] flex items-center justify-center transition group"
              title="Telegram"
            >
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161c-.18 1.897-.962 6.502-1.359 8.627-.168.9-.5 1.201-.82 1.23-.697.064-1.226-.461-1.901-.903-1.056-.692-1.653-1.123-2.678-1.799-1.185-.781-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.139-5.062 3.345-.479.329-.913.489-1.302.481-.428-.008-1.252-.241-1.865-.44-.752-.244-1.349-.374-1.297-.789.027-.216.324-.437.893-.663 3.498-1.524 5.831-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- CTA Button -->
        <button 
          onclick="openBookingModal()"
          class="px-6 py-2.5 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full transition-colors font-semibold shadow-lg hover:shadow-xl"
        >
          Записаться
        </button>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-gray-700">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100">
    <div class="container mx-auto px-4 py-4">
      
      <!-- Mobile Contacts First -->
      <div class="mb-6 pb-6 border-b border-gray-100">
        <a 
          href="tel:+79991234567" 
          class="flex items-center gap-3 text-gray-900 font-semibold text-lg mb-4"
        >
          <svg class="w-6 h-6 text-[#4894B2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          +7 (999) 123-45-67
        </a>
        
        <div class="flex gap-3">
          <a 
            href="https://wa.me/79991234567" 
            target="_blank"
            class="flex-1 py-3 bg-[#25D366] hover:bg-[#20BA5A] text-white rounded-lg font-semibold text-center transition"
          >
            WhatsApp
          </a>
          <a 
            href="https://t.me/username" 
            target="_blank"
            class="flex-1 py-3 bg-[#229ED9] hover:bg-[#1E88C5] text-white rounded-lg font-semibold text-center transition"
          >
            Telegram
          </a>
        </div>
      </div>

      <nav class="flex flex-col gap-4">
        <!-- Mobile Services Dropdown -->
        <div>
          <button id="mobile-services-toggle" class="w-full text-left text-gray-700 font-semibold flex items-center justify-between">
            Услуги
            <svg class="w-4 h-4 transition-transform" id="mobile-services-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div id="mobile-services-menu" class="hidden pl-4 mt-2 space-y-2">
            <a href="/psychology-site/services/adult" class="block text-gray-600 hover:text-[#4894B2]">Консультирование взрослых</a>
            <a href="/psychology-site/services/children" class="block text-gray-600 hover:text-[#4894B2]">Занятия с детьми</a>
          </div>
        </div>

        <!-- Mobile Programs Dropdown -->
        <div>
          <button id="mobile-programs-toggle" class="w-full text-left text-gray-700 font-semibold flex items-center justify-between">
            Программы
            <svg class="w-4 h-4 transition-transform" id="mobile-programs-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div id="mobile-programs-menu" class="hidden pl-4 mt-2 space-y-2">
            <a href="/psychology-site/services/school-prep" class="block text-gray-600 hover:text-[#4894B2]">Подготовка к школе</a>
            <a href="/psychology-site/programs/umniky" class="block text-gray-600 hover:text-[#4894B2]">Умники и умницы</a>
            <a href="/psychology-site/programs/azbuka" class="block text-gray-600 hover:text-[#4894B2]">Азбука общения</a>
          </div>
        </div>
        
        <a href="/psychology-site/specialists" class="text-gray-700 hover:text-[#4894B2]">Специалисты</a>
        <a href="/psychology-site/reviews" class="text-gray-700 hover:text-[#4894B2]">Отзывы</a>
        <a href="/psychology-site/about" class="text-gray-700 hover:text-[#4894B2]">Обо мне</a>
        <a href="/psychology-site/blog" class="text-gray-700 hover:text-[#4894B2]">Блог</a>
        <a href="/psychology-site/contact" class="text-gray-700 hover:text-[#4894B2]">Контакты</a>
        
        <button 
          onclick="openBookingModal()"
          class="w-full px-6 py-3 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-full transition-colors text-center font-semibold mt-4"
        >
          Записаться
        </button>
      </nav>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Mobile services dropdown
  const mobileServicesToggle = document.getElementById('mobile-services-toggle');
  const mobileServicesMenu = document.getElementById('mobile-services-menu');
  const mobileServicesArrow = document.getElementById('mobile-services-arrow');
  
  mobileServicesToggle?.addEventListener('click', () => {
    mobileServicesMenu?.classList.toggle('hidden');
    mobileServicesArrow?.classList.toggle('rotate-180');
  });

  // Mobile programs dropdown
  const mobileProgramsToggle = document.getElementById('mobile-programs-toggle');
  const mobileProgramsMenu = document.getElementById('mobile-programs-menu');
  const mobileProgramsArrow = document.getElementById('mobile-programs-arrow');
  
  mobileProgramsToggle?.addEventListener('click', () => {
    mobileProgramsMenu?.classList.toggle('hidden');
    mobileProgramsArrow?.classList.toggle('rotate-180');
  });
</script>
