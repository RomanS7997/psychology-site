---
// src/components/forms/BookingModal.astro
// Модальное окно записи на консультацию - многошаговая форма
---

<div class="booking-modal-overlay" id="booking-modal">
  <div class="booking-modal-content">
    <button class="modal-close" onclick="closeBookingModal()" aria-label="Закрыть">
      ✕
    </button>
    
    <div class="progress-bar">
      <div class="progress-fill" id="progress-fill"></div>
    </div>
    
    <div class="booking-steps">
      
      <!-- Шаг 1: Выбор услуги -->
      <div class="step active" data-step="1">
        <h2 class="step-title">Что вас интересует?</h2>
        <p class="step-subtitle">Выберите направление</p>
        
        <div class="options-grid">
          <button class="option-card" data-service="adult">
            <div class="option-icon">👨‍💼</div>
            <div class="option-title">Консультация взрослого</div>
            <div class="option-description">Личные проблемы, тревога, отношения</div>
          </button>
          
          <button class="option-card" data-service="child">
            <div class="option-icon">🧒</div>
            <div class="option-title">Консультация ребенка</div>
            <div class="option-description">Поведение, эмоции, развитие</div>
          </button>
          
          <button class="option-card" data-service="family">
            <div class="option-icon">👨‍👩‍👧</div>
            <div class="option-title">Семейная терапия</div>
            <div class="option-description">Конфликты, кризисы, развод</div>
          </button>
          
          <button class="option-card" data-service="program">
            <div class="option-icon">📚</div>
            <div class="option-title">Развивающая программа</div>
            <div class="option-description">Для детей 4-9 лет</div>
          </button>
        </div>
      </div>
      
      <!-- Шаг 2: Выбор специалиста -->
      <div class="step" data-step="2">
        <button class="back-btn" onclick="goToPreviousStep()">
          ← Назад
        </button>
        
        <h2 class="step-title">Выберите специалиста</h2>
        <p class="step-subtitle">Или мы подберем подходящего</p>
        
        <div class="specialists-list">
          <button class="specialist-card" data-specialist="julia">
            <img src="/psychology-site/images/specialists/julia-lyapina.jpg" alt="Юлия Ляпина" class="specialist-photo" onerror="this.src='https://via.placeholder.com/100x120/0d9488/ffffff?text=ЮЛ'">
            <div class="specialist-info">
              <div class="specialist-name">Юлия Ляпина</div>
              <div class="specialist-role">Клинический психолог</div>
              <div class="specialist-tags">
                <span class="tag">КПТ</span>
                <span class="tag">Тревога</span>
              </div>
            </div>
          </button>
          
          <button class="specialist-card" data-specialist="specialist2">
            <img src="/psychology-site/images/specialists/specialist-2.jpg" alt="Специалист 2" class="specialist-photo" onerror="this.src='https://via.placeholder.com/100x120/14b8a6/ffffff?text=СП'">
            <div class="specialist-info">
              <div class="specialist-name">Имя Фамилия</div>
              <div class="specialist-role">Детский психолог</div>
              <div class="specialist-tags">
                <span class="tag">Дети</span>
                <span class="tag">СДВГ</span>
              </div>
            </div>
          </button>
        </div>
        
        <button class="btn-text-link" onclick="selectAutoSpecialist()">
          🤔 Не знаю, помогите подобрать
        </button>
      </div>
      
      <!-- Шаг 3: Выбор даты и времени -->
      <div class="step" data-step="3">
        <button class="back-btn" onclick="goToPreviousStep()">
          ← Назад
        </button>
        
        <h2 class="step-title">Выберите удобное время</h2>
        <p class="step-subtitle">Доступные слоты на ближайшие дни</p>
        
        <div class="calendar-section">
          <div class="date-picker">
            <button class="date-option" data-date="2025-11-10">
              <div class="date-day">ПН</div>
              <div class="date-number">10</div>
              <div class="date-month">ноя</div>
            </button>
            
            <button class="date-option" data-date="2025-11-11">
              <div class="date-day">ВТ</div>
              <div class="date-number">11</div>
              <div class="date-month">ноя</div>
            </button>
            
            <button class="date-option" data-date="2025-11-12">
              <div class="date-day">СР</div>
              <div class="date-number">12</div>
              <div class="date-month">ноя</div>
            </button>
            
            <button class="date-option" data-date="2025-11-13">
              <div class="date-day">ЧТ</div>
              <div class="date-number">13</div>
              <div class="date-month">ноя</div>
            </button>
          </div>
          
          <div class="time-slots" id="time-slots">
            <button class="time-slot" data-time="10:00">10:00</button>
            <button class="time-slot" data-time="12:00">12:00</button>
            <button class="time-slot" data-time="14:00">14:00</button>
            <button class="time-slot" data-time="16:00">16:00</button>
            <button class="time-slot" data-time="18:00">18:00</button>
            <button class="time-slot disabled" data-time="20:00" disabled>20:00 (занято)</button>
          </div>
        </div>
      </div>
      
      <!-- Шаг 4: Контактные данные -->
      <div class="step" data-step="4">
        <button class="back-btn" onclick="goToPreviousStep()">
          ← Назад
        </button>
        
        <h2 class="step-title">Ваши контактные данные</h2>
        <p class="step-subtitle">Мы свяжемся с вами для подтверждения</p>
        
        <form class="booking-form" id="booking-form">
          <div class="form-group">
            <label class="form-label">Ваше имя *</label>
            <input 
              type="text" 
              name="name" 
              class="form-input" 
              placeholder="Иван Иванов"
              required
            >
          </div>
          
          <div class="form-group">
            <label class="form-label">Телефон *</label>
            <input 
              type="tel" 
              name="phone" 
              class="form-input" 
              placeholder="+7 (915) 195-51-32"
              required
            >
          </div>
          
          <div class="form-group">
            <label class="form-label">Email (необязательно)</label>
            <input 
              type="email" 
              name="email" 
              class="form-input" 
              placeholder="your@email.com"
            >
          </div>
          
          <div class="form-group">
            <label class="form-label">Кратко опишите ваш запрос</label>
            <textarea 
              name="message" 
              class="form-textarea" 
              rows="3"
              placeholder="О чем хотели бы поговорить..."
            ></textarea>
          </div>
          
          <div class="form-group">
            <label class="form-checkbox">
              <input type="checkbox" required>
              <span>Согласен с <a href="/psychology-site/privacy" target="_blank">политикой конфиденциальности</a></span>
            </label>
          </div>
          
          <button type="submit" class="form-submit-btn">
            Записаться на консультацию
          </button>
        </form>
      </div>
      
      <!-- Шаг 5: Успех -->
      <div class="step" data-step="5">
        <div class="success-content">
          <div class="success-icon">✅</div>
          <h2 class="success-title">Спасибо! Вы записаны</h2>
          <p class="success-text">
            Мы отправили подтверждение на вашу почту и позвоним вам 
            в течение <strong>15 минут</strong> для уточнения деталей.
          </p>
          
          <div class="booking-summary">
            <h3>Детали записи:</h3>
            <div class="summary-item">
              <span class="summary-label">Услуга:</span>
              <span class="summary-value" id="summary-service"></span>
            </div>
            <div class="summary-item">
              <span class="summary-label">Специалист:</span>
              <span class="summary-value" id="summary-specialist"></span>
            </div>
            <div class="summary-item">
              <span class="summary-label">Дата и время:</span>
              <span class="summary-value" id="summary-datetime"></span>
            </div>
          </div>
          
          <button class="btn-close-success" onclick="closeBookingModal()">
            Закрыть
          </button>
        </div>
      </div>
      
    </div>
  </div>
</div>

<style>
  .booking-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9998;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    padding: 1rem;
    overflow-y: auto;
  }
  
  .booking-modal-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }
  
  .booking-modal-content {
    background: white;
    border-radius: 1.5rem;
    padding: 2rem;
    max-width: 700px;
    width: 100%;
    position: relative;
    transform: scale(0.9);
    transition: transform 0.3s ease;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    max-height: 90vh;
    overflow-y: auto;
  }
  
  .booking-modal-overlay.active .booking-modal-content {
    transform: scale(1);
  }
  
  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2.5rem;
    height: 2.5rem;
    border: none;
    background: transparent;
    font-size: 1.5rem;
    color: #94a3b8;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    z-index: 10;
  }
  
  .modal-close:hover {
    color: #475569;
    background: #f1f5f9;
  }
  
  .progress-bar {
    width: 100%;
    height: 4px;
    background: #e2e8f0;
    border-radius: 2px;
    margin-bottom: 2rem;
    overflow: hidden;
  }
  
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #0d9488 0%, #14b8a6 100%);
    transition: width 0.3s ease;
    width: 20%;
  }
  
  .booking-steps {
    position: relative;
  }
  
  .step {
    display: none;
  }
  
  .step.active {
    display: block;
    animation: fadeIn 0.3s ease;
  }
  
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .step-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }
  
  .step-subtitle {
    color: #64748b;
    margin-bottom: 2rem;
  }
  
  .back-btn {
    background: none;
    border: none;
    color: #0d9488;
    font-size: 0.875rem;
    cursor: pointer;
    margin-bottom: 1rem;
    padding: 0.5rem 0;
    transition: color 0.2s ease;
  }
  
  .back-btn:hover {
    color: #0f766e;
  }
  
  .options-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  
  .option-card {
    padding: 1.5rem;
    border: 2px solid #e2e8f0;
    border-radius: 1rem;
    background: white;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: left;
  }
  
  .option-card:hover {
    border-color: #0d9488;
    background: #f0fdfa;
    transform: translateY(-2px);
  }
  
  .option-card.selected {
    border-color: #0d9488;
    background: #ccfbf1;
  }
  
  .option-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }
  
  .option-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }
  
  .option-description {
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.4;
  }
  
  .specialists-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  
  .specialist-card {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    border: 2px solid #e2e8f0;
    border-radius: 1rem;
    background: white;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: left;
  }
  
  .specialist-card:hover {
    border-color: #0d9488;
    background: #f0fdfa;
  }
  
  .specialist-card.selected {
    border-color: #0d9488;
    background: #ccfbf1;
  }
  
  .specialist-photo {
    width: 80px;
    height: 100px;
    object-fit: cover;
    border-radius: 0.75rem;
    flex-shrink: 0;
  }
  
  .specialist-info {
    flex: 1;
  }
  
  .specialist-name {
    font-size: 1.125rem;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 0.25rem;
  }
  
  .specialist-role {
    font-size: 0.875rem;
    color: #64748b;
    margin-bottom: 0.5rem;
  }
  
  .specialist-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  
  .tag {
    padding: 0.25rem 0.75rem;
    background: #e0f2fe;
    color: #0369a1;
    font-size: 0.75rem;
    border-radius: 1rem;
  }
  
  .btn-text-link {
    background: none;
    border: none;
    color: #0d9488;
    font-size: 0.9375rem;
    cursor: pointer;
    text-decoration: underline;
    padding: 0.5rem 0;
  }
  
  .calendar-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .date-picker {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
  }
  
  .date-option {
    flex-shrink: 0;
    width: 80px;
    padding: 1rem 0.5rem;
    border: 2px solid #e2e8f0;
    border-radius: 0.75rem;
    background: white;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
  }
  
  .date-option:hover {
    border-color: #0d9488;
    background: #f0fdfa;
  }
  
  .date-option.selected {
    border-color: #0d9488;
    background: #ccfbf1;
  }
  
  .date-day {
    font-size: 0.75rem;
    color: #64748b;
    margin-bottom: 0.25rem;
  }
  
  .date-number {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.25rem;
  }
  
  .date-month {
    font-size: 0.75rem;
    color: #64748b;
  }
  
  .time-slots {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  
  .time-slot {
    padding: 1rem;
    border: 2px solid #e2e8f0;
    border-radius: 0.75rem;
    background: white;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 1.125rem;
    font-weight: 600;
    color: #0f172a;
  }
  
  .time-slot:hover:not(.disabled) {
    border-color: #0d9488;
    background: #f0fdfa;
  }
  
  .time-slot.selected {
    border-color: #0d9488;
    background: #ccfbf1;
  }
  
  .time-slot.disabled {
    opacity: 0.5;
    cursor: not-allowed;
    text-decoration: line-through;
  }
  
  .booking-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .form-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #475569;
  }
  
  .form-input,
  .form-textarea {
    width: 100%;
    padding: 0.875rem 1rem;
    border: 2px solid #e2e8f0;
    border-radius: 0.75rem;
    font-size: 1rem;
    transition: all 0.2s ease;
  }
  
  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-color: #0d9488;
    box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.1);
  }
  
  .form-textarea {
    resize: vertical;
    font-family: inherit;
  }
  
  .form-checkbox {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #64748b;
    cursor: pointer;
  }
  
  .form-checkbox input[type="checkbox"] {
    width: 1.25rem;
    height: 1.25rem;
    cursor: pointer;
  }
  
  .form-checkbox a {
    color: #0d9488;
    text-decoration: underline;
  }
  
  .form-submit-btn {
    padding: 1rem;
    background: linear-gradient(135deg, #0d9488 0%, #14b8a6 100%);
    color: white;
    border: none;
    border-radius: 0.75rem;
    font-size: 1.125rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .form-submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(13, 148, 136, 0.3);
  }
  
  .success-content {
    text-align: center;
    padding: 2rem 0;
  }
  
  .success-icon {
    font-size: 5rem;
    margin-bottom: 1.5rem;
    animation: successBounce 0.6s ease;
  }
  
  @keyframes successBounce {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }
  
  .success-title {
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1rem;
  }
  
  .success-text {
    color: #64748b;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  
  .success-text strong {
    color: #0d9488;
  }
  
  .booking-summary {
    background: #f8fafc;
    border-radius: 1rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
    text-align: left;
  }
  
  .booking-summary h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 1rem;
  }
  
  .summary-item {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid #e2e8f0;
  }
  
  .summary-item:last-child {
    border-bottom: none;
  }
  
  .summary-label {
    color: #64748b;
    font-size: 0.9375rem;
  }
  
  .summary-value {
    color: #0f172a;
    font-weight: 600;
    font-size: 0.9375rem;
  }
  
  .btn-close-success {
    padding: 1rem 2rem;
    background: #0d9488;
    color: white;
    border: none;
    border-radius: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .btn-close-success:hover {
    background: #0f766e;
  }
  
  @media (max-width: 640px) {
    .booking-modal-content {
      padding: 1.5rem;
      margin: 1rem;
    }
    
    .step-title {
      font-size: 1.5rem;
    }
    
    .options-grid {
      grid-template-columns: 1fr;
    }
    
    .date-option {
      width: 70px;
      padding: 0.75rem 0.375rem;
    }
    
    .time-slots {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .specialist-photo {
      width: 60px;
      height: 75px;
    }
  }
</style>

<script is:inline>
  let bookingData = {
    service: '',
    specialist: '',
    date: '',
    time: '',
    name: '',
    phone: '',
    email: '',
    message: ''
  };
  
  let currentStep = 1;
  
  function openBookingModal() {
    const modal = document.getElementById('booking-modal');
    if (modal) {
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
      resetBookingModal();
    }
  }
  
  function closeBookingModal() {
    const modal = document.getElementById('booking-modal');
    if (modal) {
      modal.classList.remove('active');
      document.body.style.overflow = '';
      setTimeout(resetBookingModal, 300);
    }
  }
  
  function resetBookingModal() {
    currentStep = 1;
    bookingData = {
      service: '',
      specialist: '',
      date: '',
      time: '',
      name: '',
      phone: '',
      email: '',
      message: ''
    };
    goToStep(1);
  }
  
  function goToStep(step) {
    currentStep = step;
    
    document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
    
    const stepEl = document.querySelector('.step[data-step="' + step + '"]');
    if (stepEl) {
      stepEl.classList.add('active');
    }
    
    const progress = (step / 5) * 100;
    const progressFill = document.getElementById('progress-fill');
    if (progressFill) {
      progressFill.style.width = progress + '%';
    }
  }
  
  function goToPreviousStep() {
    if (currentStep > 1) {
      goToStep(currentStep - 1);
    }
  }
  
  function goToNextStep() {
    if (currentStep < 5) {
      goToStep(currentStep + 1);
    }
  }
  
  function selectAutoSpecialist() {
    bookingData.specialist = 'auto';
    goToNextStep();
  }
  
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.option-card').forEach(function(card) {
      card.addEventListener('click', function() {
        const service = card.dataset.service;
        bookingData.service = service;
        
        document.querySelectorAll('.option-card').forEach(function(c) { c.classList.remove('selected'); });
        card.classList.add('selected');
        
        setTimeout(goToNextStep, 300);
      });
    });
    
    document.querySelectorAll('.specialist-card').forEach(function(card) {
      card.addEventListener('click', function() {
        const specialist = card.dataset.specialist;
        bookingData.specialist = specialist;
        
        document.querySelectorAll('.specialist-card').forEach(function(c) { c.classList.remove('selected'); });
        card.classList.add('selected');
        
        setTimeout(goToNextStep, 300);
      });
    });
    
    document.querySelectorAll('.date-option').forEach(function(dateBtn) {
      dateBtn.addEventListener('click', function() {
        const date = dateBtn.dataset.date;
        bookingData.date = date;
        
        document.querySelectorAll('.date-option').forEach(function(d) { d.classList.remove('selected'); });
        dateBtn.classList.add('selected');
      });
    });
    
    document.querySelectorAll('.time-slot:not(.disabled)').forEach(function(timeBtn) {
      timeBtn.addEventListener('click', function() {
        const time = timeBtn.dataset.time;
        bookingData.time = time;
        
        document.querySelectorAll('.time-slot').forEach(function(t) { t.classList.remove('selected'); });
        timeBtn.classList.add('selected');
        
        setTimeout(goToNextStep, 300);
      });
    });
    
    const form = document.getElementById('booking-form');
    if (form) {
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const formData = new FormData(form);
        bookingData.name = formData.get('name');
        bookingData.phone = formData.get('phone');
        bookingData.email = formData.get('email') || '';
        bookingData.message = formData.get('message') || '';
        
        try {
          console.log('Отправка данных:', bookingData);
          
          updateBookingSummary();
          goToNextStep();
        } catch (error) {
          console.error('Ошибка отправки:', error);
          alert('Произошла ошибка. Попробуйте позвонить нам напрямую.');
        }
      });
    }
    
    const modalOverlay = document.getElementById('booking-modal');
    if (modalOverlay) {
      modalOverlay.addEventListener('click', function(e) {
        if (e.target.id === 'booking-modal') {
          closeBookingModal();
        }
      });
    }
  });
  
  function updateBookingSummary() {
    const serviceNames = {
      adult: 'Консультация взрослого',
      child: 'Консультация ребенка',
      family: 'Семейная терапия',
      program: 'Развивающая программа'
    };
    
    const specialistNames = {
      julia: 'Юлия Ляпина',
      specialist2: 'Имя Фамилия',
      auto: 'Подберем подходящего специалиста'
    };
    
    const summaryService = document.getElementById('summary-service');
    const summarySpecialist = document.getElementById('summary-specialist');
    const summaryDatetime = document.getElementById('summary-datetime');
    
    if (summaryService) summaryService.textContent = serviceNames[bookingData.service] || '';
    if (summarySpecialist) summarySpecialist.textContent = specialistNames[bookingData.specialist] || '';
    if (summaryDatetime) summaryDatetime.textContent = bookingData.date + ' в ' + bookingData.time;
  }
</script>
