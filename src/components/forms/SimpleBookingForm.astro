---
// src/components/forms/SimpleBookingForm.astro
// Упрощенная форма записи без выбора специалиста
---

<div class="booking-modal-overlay" id="booking-modal">
  <div class="booking-modal-content max-w-2xl">
    <button class="modal-close" onclick="closeBookingModal()" aria-label="Закрыть">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    
    <div class="booking-content">
      <h2 class="text-3xl font-bold text-gray-900 mb-2">Записаться на консультацию</h2>
      <p class="text-gray-600 mb-8">Заполните форму, и мы свяжемся с вами для подтверждения записи</p>

      <!-- Экран успеха (скрыт по умолчанию) -->
      <div id="booking-success" class="booking-success hidden" aria-hidden="true">
        <div class="success-confetti" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span>
          <span></span><span></span><span></span><span></span><span></span>
          <span></span><span></span><span></span><span></span><span></span>
        </div>
        <div class="success-icon">
          <svg viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
            <circle class="success-ring" cx="40" cy="40" r="36" fill="none" stroke="currentColor" stroke-width="4"/>
            <path class="success-check" d="M24 42 L36 54 L58 30" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="success-title">Заявка отправлена!</h3>
        <p class="success-text">Спасибо! Мы свяжемся с вами в ближайшее время для подтверждения записи.</p>
        <button type="button" onclick="closeBookingModal()" class="success-btn">
          Хорошо
        </button>
      </div>

      <!-- Инлайн-ошибка (скрыта по умолчанию) -->
      <div id="booking-error" class="booking-error hidden" role="alert" aria-hidden="true">
        <span class="error-icon" aria-hidden="true">⚠️</span>
        <span>Не удалось отправить заявку. Позвоните нам: <a href="tel:+79151955132" class="underline font-semibold">+7 (915) 195-51-32</a></span>
      </div>

      <form id="booking-form" class="space-y-6">
        
        <!-- Выбор услуги -->
        <div>
          <label class="block text-sm font-semibold text-gray-900 mb-3">
            Что вас интересует? <span class="text-[#4894B2]">*</span>
          </label>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <label class="option-card cursor-pointer">
              <input type="radio" name="service" value="adult" class="sr-only peer" required>
              <div class="p-4 rounded-xl border-2 border-gray-200 peer-checked:border-[#4894B2] peer-checked:bg-[#F2F7FD] transition-all">
                <div class="text-2xl mb-2">👨‍💼</div>
                <div class="font-semibold text-gray-900">Консультация взрослого</div>
                <div class="text-sm text-gray-600">Тревога, депрессия, отношения</div>
              </div>
            </label>
            
            <label class="option-card cursor-pointer">
              <input type="radio" name="service" value="child" class="sr-only peer">
              <div class="p-4 rounded-xl border-2 border-gray-200 peer-checked:border-[#4894B2] peer-checked:bg-[#F2F7FD] transition-all">
                <div class="text-2xl mb-2">🧒</div>
                <div class="font-semibold text-gray-900">Консультация ребенка</div>
                <div class="text-sm text-gray-600">Поведение, эмоции, развитие</div>
              </div>
            </label>
            
            <label class="option-card cursor-pointer">
              <input type="radio" name="service" value="family" class="sr-only peer">
              <div class="p-4 rounded-xl border-2 border-gray-200 peer-checked:border-[#4894B2] peer-checked:bg-[#F2F7FD] transition-all">
                <div class="text-2xl mb-2">👨‍👩‍👧</div>
                <div class="font-semibold text-gray-900">Семейная терапия</div>
                <div class="text-sm text-gray-600">Конфликты, кризисы</div>
              </div>
            </label>
            
            <label class="option-card cursor-pointer">
              <input type="radio" name="service" value="program" class="sr-only peer">
              <div class="p-4 rounded-xl border-2 border-gray-200 peer-checked:border-[#4894B2] peer-checked:bg-[#F2F7FD] transition-all">
                <div class="text-2xl mb-2">📚</div>
                <div class="font-semibold text-gray-900">Развивающая программа</div>
                <div class="text-sm text-gray-600">Для детей 4-9 лет</div>
              </div>
            </label>
          </div>
        </div>

        <!-- Имя -->
        <div>
          <label for="name" class="block text-sm font-semibold text-gray-900 mb-2">
            Ваше имя <span class="text-[#4894B2]">*</span>
          </label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            required
            class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-[#4894B2] focus:outline-none transition"
            placeholder="Введите ваше имя"
          >
        </div>

        <!-- Телефон -->
        <div>
          <label for="phone" class="block text-sm font-semibold text-gray-900 mb-2">
            Телефон <span class="text-[#4894B2]">*</span>
          </label>
          <input 
            type="tel" 
            id="phone" 
            name="phone" 
            required
            class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-[#4894B2] focus:outline-none transition"
            placeholder="+7 (___) ___-__-__"
          >
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-semibold text-gray-900 mb-2">
            Email
          </label>
          <input 
            type="email" 
            id="email" 
            name="email"
            class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-[#4894B2] focus:outline-none transition"
            placeholder="your@email.com"
          >
        </div>

        <!-- Комментарий -->
        <div>
          <label for="comment" class="block text-sm font-semibold text-gray-900 mb-2">
            Комментарий
          </label>
          <textarea 
            id="comment" 
            name="comment"
            rows="3"
            class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-[#4894B2] focus:outline-none transition resize-none"
            placeholder="Расскажите кратко о вашей ситуации (необязательно)"
          ></textarea>
        </div>

        <!-- Согласие на обработку данных -->
        <div class="bg-gray-50 p-4 rounded-xl">
          <label class="flex items-start gap-3 cursor-pointer">
            <input 
              type="checkbox" 
              name="privacy" 
              required
              class="mt-1 w-5 h-5 text-[#4894B2] border-gray-300 rounded focus:ring-[#4894B2]"
            >
            <span class="text-sm text-gray-700">
              Я согласен(а) на обработку персональных данных в соответствии с 
              <a href="/psychology-site/privacy" target="_blank" class="text-[#4894B2] hover:text-[#18698F] underline">
                Политикой конфиденциальности
              </a>
            </span>
          </label>
        </div>

        <!-- Кнопка отправки -->
        <div class="flex gap-4">
          <button 
            type="submit"
            class="flex-1 px-8 py-4 bg-[#4894B2] hover:bg-[#18698F] text-white rounded-xl font-bold transition-colors shadow-lg hover:shadow-xl"
          >
            Отправить заявку
          </button>
          <button 
            type="button"
            onclick="closeBookingModal()"
            class="px-8 py-4 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl font-semibold transition-colors"
          >
            Отмена
          </button>
        </div>

        <!-- Инфо -->
        <p class="text-sm text-gray-500 text-center">
          После отправки заявки мы свяжемся с вами в ближайшее время для подтверждения записи
        </p>
      </form>
    </div>
  </div>
</div>

<style>
  .booking-modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    z-index: 9999;
    overflow-y: auto;
    padding: 2rem 1rem;
  }

  .booking-modal-overlay.active {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .booking-modal-content {
    background: white;
    border-radius: 24px;
    width: 100%;
    max-width: 600px;
    position: relative;
    padding: 2.5rem;
    margin: auto;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    animation: modalSlideIn 0.3s ease-out;
  }

  @keyframes modalSlideIn {
    from {
      opacity: 0;
      transform: translateY(-30px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .modal-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #f3f4f6;
    color: #6b7280;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
    z-index: 10;
  }

  .modal-close:hover {
    background: #e5e7eb;
    color: #374151;
    transform: rotate(90deg);
  }

  @media (max-width: 640px) {
    .booking-modal-content {
      padding: 1.5rem;
      border-radius: 16px;
    }
  }

  /* ---------- Экран успеха ---------- */
  .booking-success {
    position: relative;
    text-align: center;
    padding: 1.5rem 0.5rem 0.5rem;
    animation: successFadeIn 0.5s ease-out both;
  }

  .booking-success.hidden { display: none; }

  @keyframes successFadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .success-icon {
    display: inline-flex;
    color: #4894B2;
    margin-bottom: 1.25rem;
    filter: drop-shadow(0 8px 20px rgba(72, 148, 178, 0.35));
  }

  .success-icon svg { overflow: visible; }

  .success-ring {
    stroke-dasharray: 226;
    stroke-dashoffset: 226;
    animation: drawRing 0.55s 0.05s ease-out forwards;
    transform-origin: 40px 40px;
  }

  .success-check {
    stroke-dasharray: 60;
    stroke-dashoffset: 60;
    animation: drawCheck 0.35s 0.55s ease-out forwards;
  }

  @keyframes drawRing {
    to { stroke-dashoffset: 0; }
  }

  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }

  .success-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.75rem;
    animation: successPop 0.4s 0.65s ease-out both;
  }

  .success-text {
    color: #475569;
    line-height: 1.6;
    margin-bottom: 1.75rem;
    animation: successPop 0.4s 0.8s ease-out both;
  }

  @keyframes successPop {
    from { opacity: 0; transform: scale(0.92); }
    to   { opacity: 1; transform: scale(1); }
  }

  .success-btn {
    padding: 0.875rem 2.5rem;
    background: linear-gradient(135deg, #4894B2 0%, #18698F 100%);
    color: white;
    border: none;
    border-radius: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 6px 20px rgba(72, 148, 178, 0.35);
    animation: successPop 0.4s 0.95s ease-out both;
  }

  .success-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(72, 148, 178, 0.45);
  }

  /* Конфетти */
  .success-confetti {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: visible;
  }

  .success-confetti span {
    position: absolute;
    left: 50%;
    top: 60px;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    opacity: 0;
    animation: confettiBurst 1.1s 0.6s ease-out forwards;
  }

  .success-confetti span:nth-child(1)  { background: #4894B2; --tx:  -160px; --ty: -120px; --r: -40deg; }
  .success-confetti span:nth-child(2)  { background: #d9797d; --tx:   140px; --ty: -140px; --r:  50deg; }
  .success-confetti span:nth-child(3)  { background: #f2b134; --tx:  -220px; --ty:  -40px; --r: -80deg; }
  .success-confetti span:nth-child(4)  { background: #7fb685; --tx:   220px; --ty:  -20px; --r:  90deg; }
  .success-confetti span:nth-child(5)  { background: #4894B2; --tx:   -80px; --ty: -180px; --r: -20deg; border-radius: 50%; }
  .success-confetti span:nth-child(6)  { background: #d9797d; --tx:    80px; --ty: -180px; --r:  20deg; border-radius: 50%; }
  .success-confetti span:nth-child(7)  { background: #18698F; --tx:  -260px; --ty:   40px; --r: -110deg; }
  .success-confetti span:nth-child(8)  { background: #f2b134; --tx:   260px; --ty:   60px; --r:  110deg; }
  .success-confetti span:nth-child(9)  { background: #7fb685; --tx:  -120px; --ty:  -80px; --r: -60deg; border-radius: 50%; }
  .success-confetti span:nth-child(10) { background: #4894B2; --tx:   120px; --ty:  -90px; --r:  60deg; border-radius: 50%; }
  .success-confetti span:nth-child(11) { background: #d9797d; --tx:  -200px; --ty:  120px; --r: -140deg; }
  .success-confetti span:nth-child(12) { background: #18698F; --tx:   200px; --ty:  140px; --r:  140deg; }
  .success-confetti span:nth-child(13) { background: #f2b134; --tx:   -40px; --ty: -220px; --r:   10deg; border-radius: 50%; }
  .success-confetti span:nth-child(14) { background: #7fb685; --tx:    40px; --ty: -220px; --r:  -10deg; border-radius: 50%; }
  .success-confetti span:nth-child(15) { background: #4894B2; --tx:     0px; --ty: -260px; --r:   30deg; }

  @keyframes confettiBurst {
    0% {
      opacity: 0;
      transform: translate(-50%, 0) rotate(0deg) scale(0.6);
    }
    15% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translate(calc(-50% + var(--tx)), var(--ty)) rotate(var(--r)) scale(1);
    }
  }

  /* ---------- Ошибка ---------- */
  .booking-error {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #991b1b;
    padding: 1rem 1.25rem;
    border-radius: 0.75rem;
    margin-bottom: 1rem;
    animation: errorShake 0.5s ease-out;
  }

  .booking-error.hidden { display: none; }

  .booking-error .error-icon { font-size: 1.25rem; flex-shrink: 0; }

  @keyframes errorShake {
    0%, 100% { transform: translateX(0); }
    20%      { transform: translateX(-6px); }
    40%      { transform: translateX(6px); }
    60%      { transform: translateX(-4px); }
    80%      { transform: translateX(4px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .booking-success,
    .success-ring,
    .success-check,
    .success-title,
    .success-text,
    .success-btn,
    .success-confetti span,
    .booking-error {
      animation: none !important;
    }
    .success-ring, .success-check { stroke-dashoffset: 0; }
  }
</style>

<script>
  function resetBookingView() {
    const form = document.getElementById('booking-form');
    const success = document.getElementById('booking-success');
    const errorBox = document.getElementById('booking-error');
    if (form) form.classList.remove('hidden');
    if (success) {
      success.classList.add('hidden');
      success.setAttribute('aria-hidden', 'true');
      // Перезапуск CSS-анимаций: форсируем reflow, сбрасывая классы
      success.style.animation = 'none';
      void success.offsetWidth;
      success.style.animation = '';
    }
    if (errorBox) {
      errorBox.classList.add('hidden');
      errorBox.setAttribute('aria-hidden', 'true');
    }
  }

  function openBookingModal() {
    const modal = document.getElementById('booking-modal');
    if (modal) {
      resetBookingView();
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeBookingModal() {
    const modal = document.getElementById('booking-modal');
    if (modal) {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    }
  }

  // Закрытие по клику вне модального окна
  document.getElementById('booking-modal')?.addEventListener('click', (e) => {
    if (e.target.id === 'booking-modal') {
      closeBookingModal();
    }
  });

  // Закрытие по Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeBookingModal();
    }
  });

  // Обработка формы — отправка через FormSubmit.co на lyapina_sorokina@mail.ru
  document.getElementById('booking-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const form = e.target;
    const formData = new FormData(form);
    const serviceLabels = {
      adult: 'Консультация взрослого',
      child: 'Консультация ребенка',
      family: 'Семейная терапия',
      program: 'Развивающая программа'
    };

    const payload = {
      _subject: 'Новая заявка с сайта — запись на консультацию',
      _template: 'table',
      _captcha: 'false',
      Услуга: serviceLabels[formData.get('service')] || formData.get('service') || '—',
      Имя: formData.get('name') || '—',
      Телефон: formData.get('phone') || '—',
      Email: formData.get('email') || '—',
      Комментарий: formData.get('comment') || '—',
      Источник: 'Форма записи (julialyapina.ru)'
    };

    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn ? submitBtn.textContent : '';
    const errorBox = document.getElementById('booking-error');
    const successBox = document.getElementById('booking-success');

    if (errorBox) {
      errorBox.classList.add('hidden');
      errorBox.setAttribute('aria-hidden', 'true');
    }
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Отправка...';
    }

    try {
      const response = await fetch('https://formsubmit.co/ajax/lyapina_sorokina@mail.ru', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(payload)
      });

      if (!response.ok) throw new Error('Ошибка отправки');

      // Показываем красивый экран успеха
      form.reset();
      form.classList.add('hidden');
      if (successBox) {
        successBox.classList.remove('hidden');
        successBox.setAttribute('aria-hidden', 'false');
        // Форсируем перезапуск анимаций
        successBox.style.animation = 'none';
        void successBox.offsetWidth;
        successBox.style.animation = '';
      }
    } catch (err) {
      if (errorBox) {
        errorBox.classList.remove('hidden');
        errorBox.setAttribute('aria-hidden', 'false');
        // Перезапуск shake-анимации
        errorBox.style.animation = 'none';
        void errorBox.offsetWidth;
        errorBox.style.animation = '';
      }
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    }
  });

  // Форматирование телефона (фикс: разделители не дописываются
  // пока следующего разряда нет — backspace удаляет по одной цифре)
  const phoneInput = document.getElementById('phone');
  phoneInput?.addEventListener('input', (e) => {
    let digits = e.target.value.replace(/\D/g, '');
    if (digits.startsWith('7') || digits.startsWith('8')) {
      digits = digits.substring(1);
    }
    digits = digits.substring(0, 10);

    if (digits.length === 0) {
      e.target.value = '';
      return;
    }

    let formatted = '+7 (' + digits.substring(0, 3);
    if (digits.length > 3) formatted += ') ' + digits.substring(3, 6);
    if (digits.length > 6) formatted += '-' + digits.substring(6, 8);
    if (digits.length > 8) formatted += '-' + digits.substring(8, 10);

    e.target.value = formatted;
  });

  // Глобальные функции для доступа из других скриптов
  window.openBookingModal = openBookingModal;
  window.closeBookingModal = closeBookingModal;
</script>
